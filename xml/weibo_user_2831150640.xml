g8jsk.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqltdvf9c2j20ll0g8dh3.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqltdvfj2qj20ll0g8q47.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqltdvz4xhj216g0u0wia.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqltdvkh7rj216g0u0wig.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqltdvkzggj216g0u0juz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hqltdvkvclj216g0u042h.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqltdvmw1ej216g0u0gp9.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Oiyh59NTt</link><guid isPermaLink="false">https://weibo.com/2831150640/Oiyh59NTt</guid><pubDate>Tue, 11 Jun 2024 15:06:55 GMT</pubDate><author>深圳卫健委</author><category>疾病风险预报</category></item><item><title>🍉水果吃不够，会影响健康吗？会，甚至可能“要命”！早在2019 年，权威医学期刊《柳叶刀》就发布了全球饮食领域的大规模研究——195个国家和地区饮食结构造成...</title><description>🍉水果吃不够，会影响健康吗？&lt;br&gt;&lt;br&gt;会，甚至可能“要命”！&lt;br&gt;&lt;br&gt;早在2019 年，权威医学期刊《柳叶刀》就发布了全球饮食领域的大规模研究——195个国家和地区饮食结构造成的死亡率和疾病负担。其中，仅2017年一年，因为水果没吃够而死亡的人数就有约200万。另外，根据《中国居民膳食指南（2022）》建议，每人每天摄入200-350克新鲜水果。&lt;br&gt;&lt;br&gt;克数怎么拿捏？🤏🏻&lt;br&gt;&lt;br&gt;一个中等大小的苹果，去核大约200克，一个去皮的猕猴桃，大约100克，一根去皮的香蕉，大约120克。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlozf1jupj20u02gwdnk.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OixhfE3ce</link><guid isPermaLink="false">https://weibo.com/2831150640/OixhfE3ce</guid><pubDate>Tue, 11 Jun 2024 12:34:36 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category><category>小卫来辟谣</category></item><item><title>【[思考]#高考后家长不能做的6件事#】高考结束了，在备考期间，孩子一直处于心情紧张的高压状态，现在突然得到释放，情绪可能会出现急剧变化。孩子高考后可能会...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[思考]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_sikao-ff9602dd08.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E9%AB%98%E8%80%83%E5%90%8E%E5%AE%B6%E9%95%BF%E4%B8%8D%E8%83%BD%E5%81%9A%E7%9A%846%E4%BB%B6%E4%BA%8B%23&amp;amp;extparam=%23%E9%AB%98%E8%80%83%E5%90%8E%E5%AE%B6%E9%95%BF%E4%B8%8D%E8%83%BD%E5%81%9A%E7%9A%846%E4%BB%B6%E4%BA%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#高考后家长不能做的6件事#&lt;/span&gt;&lt;/a&gt;】高考结束了，在备考期间，孩子一直处于心情紧张的高压状态，现在突然得到释放，情绪可能会出现急剧变化。孩子高考后可能会有哪些变化？作为家长，应该怎么和孩子相处？最好不要做哪些事？👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（科普中国） &lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqlj4xvszqj20p00xctgx.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xtn93j20p00xcn4o.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqlj4xhgtij20p00xcwkk.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xtpocj20p00xc7dj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xta59j20p00xcguj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqlj4xo8o9j20p00xcdot.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xqq2jj20p00xcjzt.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlj4xtr4fj20p00xc7di.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlj4xoypdj20p00xcdno.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hqlj4y3n0uj20p00xc0yq.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hqlj4ydg4zj20p00xcahz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xvhjpj20p00xcgtn.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hqlj4xw4smj20p00xcgrq.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlj4xvgfmj20p00xcwmo.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqlj4xv2udj20p00xctfw.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OivX9AQqj</link><guid isPermaLink="false">https://weibo.com/2831150640/OivX9AQqj</guid><pubDate>Tue, 11 Jun 2024 09:12:20 GMT</pubDate><author>深圳卫健委</author><category>高考后家长不能做的6件事</category><category>小卫来辟谣</category></item><item><title>[哆啦A梦汗]#手上青筋凸起是人体亚健康吗#？你们身边有没有一些人，有些地方的皮肤会青筋凸起，像地图的经纬线......这些青筋，其实是位于皮下表浅层静脉血管。...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[哆啦A梦汗]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/doraemon/dr_04han-372a719d21.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%89%8B%E4%B8%8A%E9%9D%92%E7%AD%8B%E5%87%B8%E8%B5%B7%E6%98%AF%E4%BA%BA%E4%BD%93%E4%BA%9A%E5%81%A5%E5%BA%B7%E5%90%97%23&amp;amp;extparam=%23%E6%89%8B%E4%B8%8A%E9%9D%92%E7%AD%8B%E5%87%B8%E8%B5%B7%E6%98%AF%E4%BA%BA%E4%BD%93%E4%BA%9A%E5%81%A5%E5%BA%B7%E5%90%97%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#手上青筋凸起是人体亚健康吗#&lt;/span&gt;&lt;/a&gt;？你们身边有没有一些人，有些地方的皮肤会青筋凸起，像地图的经纬线......这些青筋，其实是位于皮下表浅层静脉血管。&lt;br&gt;&lt;br&gt;一般来说，在温度较高时，人体血液流通较快，血管会扩张，可能就会导致青筋凸起，这并不代表身体有问题。但身体这3处地方如果出现青筋，建议到医院查一查👇🏻&lt;br&gt;&lt;br&gt;①下肢：这是下肢静脉曲张的典型表现。严重时可能造成肺栓塞，引发猝死。&lt;br&gt;&lt;br&gt;②颈部：当脖子上出现异常凸起的青筋，就得警惕是“颈静脉怒张”。这是右心房功能受损的症状，严重起来，可能会心梗、心力衰竭。&lt;br&gt;&lt;br&gt;③腹部：一般来说，腹部很少会出现青筋。当发生肝硬化、腹水、腹腔内肿瘤挤压脏器时，静脉血液回流就会受阻，导致血管膨胀，出现又粗又直的青筋。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（深圳大学总医院）&lt;br&gt;&lt;br&gt;青筋凸起，也别大意！&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlgfk8y3ij20m80comz5.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlgfk8sdej20m80cotao.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlgfk90osj20m80coq4x.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Oivla9txE</link><guid isPermaLink="false">https://weibo.com/2831150640/Oivla9txE</guid><pubDate>Tue, 11 Jun 2024 07:38:44 GMT</pubDate><author>深圳卫健委</author><category>手上青筋凸起是人体亚健康吗</category><category>小卫唠健康</category><category>小卫来辟谣</category></item><item><title>【深圳女生42秒就睡着！这种“超能力”竟然是种病😴】小安（化名）从初二开始，就是一名“特困生”，为啥这么说？因为她觉太多，总睡不够。她会突然睡着，然后...</title><description>【深圳女生42秒就睡着！这种“超能力”竟然是种病😴】小安（化名）从初二开始，就是一名“特困生”，为啥这么说？因为她觉太多，总睡不够。她会突然睡着，然后又突然醒来，而且越来越频繁，后来甚至一天有一大半时间都在睡觉。&lt;br&gt;&lt;br&gt;想着可能是学习压力大，父母和老师也没太在意。&lt;br&gt;&lt;br&gt;现在她已经毕业工作了，可嗜睡的毛病还是挥之不去。前段时间，小安发现自己走路、搬砖、甚至和朋友闲聊时，困意就会袭来，自己根本无力对抗，直接秒睡。&lt;br&gt;&lt;br&gt;一次偶然，小安看到“女孩基因突变，最快48秒睡着，确诊‘发作性睡病’”的新闻。她对照症状，这不就是自己吗？再也不想拖了，小安果断来到深圳大学总医院，找到了电视里的黄若兰医生。&lt;br&gt;&lt;br&gt;医生为她做了5次小睡试验，她都在7分钟以内睡着，从关灯到睡着的时间只有3.2分钟，最短的一次，42秒就睡着了。&lt;br&gt;&lt;br&gt;经过详细问诊和检查，小安也被确诊为：发作性睡病。&lt;br&gt;&lt;br&gt;一般来说，正常人从躺床上到睡着的平均时间是10-30分钟，如果入睡时间过短，没有睡眠不足，又频繁在8分钟内睡着，白天又出现秒睡、或睡不醒的状态，最好去医院查查。&lt;br&gt;&lt;br&gt;遗憾的是，这种病目前还不能治愈，但可以对症下药进行控制。&lt;br&gt;&lt;br&gt;2023年9月，在《第二批罕见病目录》中，发作性睡病被列入其中。同年12月，用于治疗发作性睡病的替洛利生片，进入新版医保目录。&lt;br&gt;&lt;br&gt;黄若兰马上向医院申请，很快，药物配送到货。目前，小安已经顺利用药。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E7%A7%91%E6%99%AE%E6%95%85%E4%BA%8B%E6%B1%87%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E7%A7%91%E6%99%AE%E6%95%85%E4%BA%8B%E6%B1%87%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫科普故事汇#&lt;/span&gt;&lt;/a&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hqlerfhazsj20zk0np795.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hqlerfi4cuj20zk0qojv9.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqlerfftkrj20hs0hs3zo.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OiuXHqUs1</link><guid isPermaLink="false">https://weibo.com/2831150640/OiuXHqUs1</guid><pubDate>Tue, 11 Jun 2024 06:40:56 GMT</pubDate><author>深圳卫健委</author><category>小卫科普故事汇</category></item><item><title>近日，某酸奶门店被曝使用超过保质期的原料引起关注[吐] 食物的保质期越短，就越安全？临期食品能放心吃吗？一起学习👇🏻#小卫唠健康#（科普中国）科普一下...</title><description>近日，某酸奶门店被曝使用超过保质期的原料引起关注&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吐]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_tu-cfbe704573.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; 食物的保质期越短，就越安全？临期食品能放心吃吗？一起学习👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5042658406760467&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;科普一下的微博视频&lt;/span&gt;&lt;/a&gt; &lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax2.sinaimg.cn/orj480/008tX9qwly1hqgufjuy8zj31hc0u0wne.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/nKNxKqT4lx08fsVIYZny01041200NNWy0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=Gc6%2BCjinvP&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/tnhiebQBlx08fsVHl8hi01041200rAl50E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=D6%2FKxhufQb&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/MbGZPNwAlx08fsVHddRC01041200ig9M0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=g074zH9wo6&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5042658406760467&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OiuiffAUD</link><guid isPermaLink="false">https://weibo.com/2831150640/OiuiffAUD</guid><pubDate>Tue, 11 Jun 2024 04:58:48 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category></item><item><title>#为什么女性更容易得甲状腺结节# 有报道说，女性患甲状腺结节的概率，大约为男性的3倍，是真的吗？是真的🤦🏻♀️ 出现这种现象的原因，医学界目前还没有确...</title><description>&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E4%B8%BA%E4%BB%80%E4%B9%88%E5%A5%B3%E6%80%A7%E6%9B%B4%E5%AE%B9%E6%98%93%E5%BE%97%E7%94%B2%E7%8A%B6%E8%85%BA%E7%BB%93%E8%8A%82%23&amp;amp;extparam=%23%E4%B8%BA%E4%BB%80%E4%B9%88%E5%A5%B3%E6%80%A7%E6%9B%B4%E5%AE%B9%E6%98%93%E5%BE%97%E7%94%B2%E7%8A%B6%E8%85%BA%E7%BB%93%E8%8A%82%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#为什么女性更容易得甲状腺结节#&lt;/span&gt;&lt;/a&gt; 有报道说，女性患甲状腺结节的概率，大约为男性的3倍，是真的吗？&lt;br&gt;&lt;br&gt;是真的🤦🏻♀️ 出现这种现象的原因，医学界目前还没有确切的答案，其中一种推测是——激素。&lt;br&gt;&lt;br&gt;女性的身体里，存在多种激素，包括与月经周期紧密相关的激素（卵泡刺激素、黄体生成素等），和由甲状腺分泌的甲状腺激素。这些激素之间会彼此影响，一种激素的分泌发生变化，另一种也可能会发生改变。&lt;br&gt;&lt;br&gt;随着月经周期的推进，与其相关的激素会发生剧烈波动，甲状腺激素也会受到影响，久而久之，就可能引起甲状腺疾病，比如甲状腺结节。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hql8rhi646j20u00uqq6i.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hql8rhhnaij20mq0sg76n.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hql8rhhlh2j20u00u3wgg.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OitBsuUM7</link><guid isPermaLink="false">https://weibo.com/2831150640/OitBsuUM7</guid><pubDate>Tue, 11 Jun 2024 03:13:24 GMT</pubDate><author>深圳卫健委</author><category>为什么女性更容易得甲状腺结节</category><category>小卫唠健康</category><category>小卫来辟谣</category></item><item><title>[开学季]高考完，迎来摘镜热！我适合近视手术吗？做完手术不会再近视了？一波及时科普来了👇🏻近视手术，并不是治愈近视。而是通过切削角膜或植入人工晶体，...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[开学季]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/72/2021_kaixueji_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;高考完，迎来摘镜热！我适合近视手术吗？做完手术不会再近视了？一波及时科普来了👇🏻&lt;br&gt;&lt;br&gt;近视手术，并不是治愈近视。而是通过切削角膜或植入人工晶体，改变眼球屈光度，让光线重新聚焦在视网膜上（相当于把眼镜做进眼睛里，眼睛还是近视眼）。&lt;br&gt;&lt;br&gt;做完手术之后，要听医生的话，定期复查。&amp;nbsp;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%BF%91%E8%A7%86%E6%89%8B%E6%9C%AF%E5%B9%B6%E4%B8%8D%E6%98%AF%E4%B8%80%E5%8A%B3%E6%B0%B8%E9%80%B8%23&amp;amp;extparam=%23%E8%BF%91%E8%A7%86%E6%89%8B%E6%9C%AF%E5%B9%B6%E4%B8%8D%E6%98%AF%E4%B8%80%E5%8A%B3%E6%B0%B8%E9%80%B8%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#近视手术并不是一劳永逸#&lt;/span&gt;&lt;/a&gt;，不良的用眼习惯（比如过度用眼等），有可能就白挨“削”了。如果你有这些状况——&lt;br&gt;&lt;br&gt;①眼部疾病，比如严重视网膜相关疾病、严重干眼症等。&lt;br&gt;②全身结缔组织疾病或自身免疫病，比如系统性红斑狼疮、多发性硬化等。&lt;br&gt;③怀孕、哺乳期。&lt;br&gt;&lt;br&gt;眼镜该戴咱就戴吧&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[并不简单]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_bingbujiandan-9955880b30.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（深圳市眼科医院）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hql7eqkc95j20u01f6do3.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hql7eq4u91j20hs0hs752.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OitirF7u7</link><guid isPermaLink="false">https://weibo.com/2831150640/OitirF7u7</guid><pubDate>Tue, 11 Jun 2024 02:26:33 GMT</pubDate><author>深圳卫健委</author><category>近视手术并不是一劳永逸</category><category>小卫唠健康</category><category>小卫来辟谣</category></item><item><title>【[话筒]提醒！#肉毒素中毒严重或危及生命#】肉毒素，是指一类能够抑制肌肉收缩的药物，它有让脸部或身体不同部位变瘦、祛除皱纹等功效。近期，医院肉毒素中毒的...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;提醒！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%82%89%E6%AF%92%E7%B4%A0%E4%B8%AD%E6%AF%92%E4%B8%A5%E9%87%8D%E6%88%96%E5%8D%B1%E5%8F%8A%E7%94%9F%E5%91%BD%23&amp;amp;extparam=%23%E8%82%89%E6%AF%92%E7%B4%A0%E4%B8%AD%E6%AF%92%E4%B8%A5%E9%87%8D%E6%88%96%E5%8D%B1%E5%8F%8A%E7%94%9F%E5%91%BD%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#肉毒素中毒严重或危及生命#&lt;/span&gt;&lt;/a&gt;】肉毒素，是指一类能够抑制肌肉收缩的药物，它有让脸部或身体不同部位变瘦、祛除皱纹等功效。近期，医院肉毒素中毒的患者激增，年龄最小的不到20岁，最大的超过60岁！肉毒素中毒症状为头晕眼花、乏力等，更严重可能会出现呼吸衰竭，甚至可能危及生命。 &lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%9C%89%E4%BA%9B%E4%BA%BA%E4%B8%8D%E9%80%82%E5%90%88%E6%B3%A8%E5%B0%84%E8%82%89%E6%AF%92%E7%B4%A0%23&amp;amp;extparam=%23%E6%9C%89%E4%BA%9B%E4%BA%BA%E4%B8%8D%E9%80%82%E5%90%88%E6%B3%A8%E5%B0%84%E8%82%89%E6%AF%92%E7%B4%A0%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#有些人不适合注射肉毒素#&lt;/span&gt;&lt;/a&gt;：①怀孕、哺乳期；②对肉毒素蛋白有过敏史；③注射区域有感染等。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;小卫提醒，理性爱美！（央视新闻）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5039500284330035&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax3.sinaimg.cn/orj480/002TLsr9ly1hq6ru7czs8j61hc0u0qj002.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/8eJQf175lx08ff2iqVzW01041202aLVo0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=BYPfJm7vDM&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/yXu4J2GZlx08ff2imyCk01041201axGc0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=rcN%2Bi2sUwA&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/jLWGWmSolx08ff2gPGre01041200GAO90E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1718140259&amp;amp;ssig=nt20ItbAeQ&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5039500284330035&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/Oime6cPSE</link><guid isPermaLink="false">https://weibo.com/2831150640/Oime6cPSE</guid><pubDate>Mon, 10 Jun 2024 08:26:37 GMT</pubDate><author>深圳卫健委</author><category>肉毒素中毒严重或危及生命</category><category>有些人不适合注射肉毒素</category></item><item><title>[二哈]#3个洗碗坏习惯或增加患癌风险# 这4个洗碗错误的坏习惯，几乎每个人都有中招的！①不立即洗：不少人刚吃完饭会把碗筷先用水泡着，过一会儿再洗，这么做容...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[二哈]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_erha-139d0e07bd.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%233%E4%B8%AA%E6%B4%97%E7%A2%97%E5%9D%8F%E4%B9%A0%E6%83%AF%E6%88%96%E5%A2%9E%E5%8A%A0%E6%82%A3%E7%99%8C%E9%A3%8E%E9%99%A9%23&amp;amp;extparam=%233%E4%B8%AA%E6%B4%97%E7%A2%97%E5%9D%8F%E4%B9%A0%E6%83%AF%E6%88%96%E5%A2%9E%E5%8A%A0%E6%82%A3%E7%99%8C%E9%A3%8E%E9%99%A9%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#3个洗碗坏习惯或增加患癌风险#&lt;/span&gt;&lt;/a&gt; 这4个洗碗错误的坏习惯，几乎每个人都有中招的！&lt;br&gt;&lt;br&gt;①不立即洗：不少人刚吃完饭会把碗筷先用水泡着，过一会儿再洗，这么做容易滋生细菌，有异味。&amp;nbsp;&lt;br&gt;&lt;br&gt;②不更换洗碗布：研究显示，擦碗布的细菌数量非常高，最好一个月左右更换一次，而且擦碗布一定要专门用来擦碗。&lt;br&gt;&lt;br&gt;③洗洁精直接倒在碗上：这样容易用量超标、冲洗不干净。如果被我们吃进去，可能会引发肠胃不适。正确做法是将几滴洗洁精滴到半碗水中稀释，用洗碗布蘸着稀释后的水来洗。&lt;br&gt;&lt;br&gt;④餐具不消毒：高温消毒是最常用的消毒方法，把碗筷煮沸5-10分钟后，大部分细菌、病毒都能杀死。如果条件允许，最好使用消毒机对碗筷进行高温消毒。&lt;br&gt;&lt;br&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;洗完碗要立起来存放，这样容易沥干，即使有一点食物残渣也不容易滋生细菌。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hqk5bzp8cug209i05oh3w.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hqk5bztlrrj20kj0kjjtv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OikFIc3VD</link><guid isPermaLink="false">https://weibo.com/2831150640/OikFIc3VD</guid><pubDate>Mon, 10 Jun 2024 04:29:09 GMT</pubDate><author>深圳卫健委</author><category>3个洗碗坏习惯或增加患癌风险</category><category>小卫来辟谣</category></item></channel></rss>