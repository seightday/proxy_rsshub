%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（深圳疾控） &lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpp9m5uu46j20u00iemzr.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OegR1eXrJ</link><guid isPermaLink="false">https://weibo.com/2831150640/OegR1eXrJ</guid><pubDate>Tue, 14 May 2024 11:24:48 GMT</pubDate><author>深圳卫健委</author></item><item><title>【[话筒]深圳市第186期#疾病风险预报# 结果出炉！】深圳市第186期疾病风险预报结果如下：2024年5月15日至2024年5月21日，手足口和流感风险为“中”，其余病种风...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;深圳市第186期&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E7%96%BE%E7%97%85%E9%A3%8E%E9%99%A9%E9%A2%84%E6%8A%A5%23&amp;amp;extparam=%23%E7%96%BE%E7%97%85%E9%A3%8E%E9%99%A9%E9%A2%84%E6%8A%A5%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#疾病风险预报#&lt;/span&gt;&lt;/a&gt; 结果出炉！】深圳市第186期疾病风险预报结果如下：2024年5月15日至2024年5月21日，手足口和流感风险为“中”，其余病种风险为“低”。 &lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpp7ms8jkgj20ll0g8ta5.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hpp7ms9bm3j20ll0g8myh.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hpp7ms95f3j20ll0g8gms.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hpp7ms7bwxj20ll0g8dh3.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpp7ms9ndhj20ll0g8q47.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpp7msewj8j216g0u00wj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpp7msf75zj216g0u00wp.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hpp7msevo8j216g0u0n0r.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hpp7msewsqj216g0u042h.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpp7msf5e6j216g0u0jv1.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OegpblbfC</link><guid isPermaLink="false">https://weibo.com/2831150640/OegpblbfC</guid><pubDate>Tue, 14 May 2024 10:16:13 GMT</pubDate><author>深圳卫健委</author></item><item><title>🛌#那些长期赖床的人怎么样了#赖床能保命。[awsl]闹钟一响马上起床，血管会迅速收缩，容易引起大脑供血不足，引发中风、猝死等意外。瑞典斯德哥尔摩大学研究发...</title><description>🛌&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E9%82%A3%E4%BA%9B%E9%95%BF%E6%9C%9F%E8%B5%96%E5%BA%8A%E7%9A%84%E4%BA%BA%E6%80%8E%E4%B9%88%E6%A0%B7%E4%BA%86%23&amp;amp;extparam=%23%E9%82%A3%E4%BA%9B%E9%95%BF%E6%9C%9F%E8%B5%96%E5%BA%8A%E7%9A%84%E4%BA%BA%E6%80%8E%E4%B9%88%E6%A0%B7%E4%BA%86%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#那些长期赖床的人怎么样了#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;赖床能保命。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[awsl]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/fb_a3awsl-ed1a33c1b3.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;闹钟一响马上起床，血管会迅速收缩，容易引起大脑供血不足，引发中风、猝死等意外。&lt;br&gt;&lt;br&gt;瑞典斯德哥尔摩大学研究发现：闹钟第一次响了之后，把它摁掉，再睡上 30 分钟，醒来时头脑会更敏捷，精神状态也会更好。所以，在不迟到的前提下，把闹钟向后拨一拨，裹紧小被子，再睡30分钟吧&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpp4pvze2bj20mu0rk770.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OefKg4xpq</link><guid isPermaLink="false">https://weibo.com/2831150640/OefKg4xpq</guid><pubDate>Tue, 14 May 2024 08:35:23 GMT</pubDate><author>深圳卫健委</author></item><item><title>[揣手]#比砒霜还毒几十倍的致癌物# 黄曲霉毒素真的很恐怖，它的毒性是砒霜的68倍、氰化钾的10倍，只要1毫克，就能致癌，属于超级致癌物！一旦误食黄曲霉毒素，轻...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[揣手]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/af/2022_chuaishou_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%AF%94%E7%A0%92%E9%9C%9C%E8%BF%98%E6%AF%92%E5%87%A0%E5%8D%81%E5%80%8D%E7%9A%84%E8%87%B4%E7%99%8C%E7%89%A9%23&amp;amp;extparam=%23%E6%AF%94%E7%A0%92%E9%9C%9C%E8%BF%98%E6%AF%92%E5%87%A0%E5%8D%81%E5%80%8D%E7%9A%84%E8%87%B4%E7%99%8C%E7%89%A9%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#比砒霜还毒几十倍的致癌物#&lt;/span&gt;&lt;/a&gt; 黄曲霉毒素真的很恐怖，它的毒性是砒霜的68倍、氰化钾的10倍，只要1毫克，就能致癌，属于超级致癌物！&lt;br&gt;&lt;br&gt;一旦误食黄曲霉毒素，轻则发热、呕吐、腹痛等，重则引发暴发性肝衰竭、肾功能衰竭等，甚至死亡。黄曲霉菌喜欢温暖潮湿的环境，适宜生长温度在37℃左右。一般来说，黄曲霉喜欢藏在这些地方——&lt;br&gt;&lt;br&gt;①久泡的木耳；&lt;br&gt;②发苦的坚果；&lt;br&gt;③变质的大米；&lt;br&gt;④发霉的玉米、花生；&lt;br&gt;⑤长期不清理的冰箱；&lt;br&gt;⑥小作坊的自榨油；&lt;br&gt;⑦用久了的筷子、砧板。&lt;br&gt;&lt;br&gt;即使加热，黄曲霉毒素要到280℃以上才会分解，一般的烹饪温度，根本达不到这个水平。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;听卫一句劝，发现家中的大米、花生、坚果等食物发霉，千万别再食用；筷子、砧板等厨具要及时清洗，定期更换；食材也不要一次性买太多，不要为了省一点点钱，去承担患癌的风险。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康广东）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpp2t3o8hij20u00llq7b.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpp2t3pizhj20g00970to.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hpp2t427rog20ak055qv5.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OefjqzXfH</link><guid isPermaLink="false">https://weibo.com/2831150640/OefjqzXfH</guid><pubDate>Tue, 14 May 2024 07:29:17 GMT</pubDate><author>深圳卫健委</author></item><item><title>【野生菌子陆续上市！#炫蘑菇牢记4个不吃#】那些喜欢“以身试毒”的人，我劝你别乱来，命只有一条[微笑]。吃菌子，记好这4点：①不认识、不熟悉的不吃；②杂菌混...</title><description>【野生菌子陆续上市！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E7%82%AB%E8%98%91%E8%8F%87%E7%89%A2%E8%AE%B04%E4%B8%AA%E4%B8%8D%E5%90%83%23&amp;amp;extparam=%23%E7%82%AB%E8%98%91%E8%8F%87%E7%89%A2%E8%AE%B04%E4%B8%AA%E4%B8%8D%E5%90%83%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#炫蘑菇牢记4个不吃#&lt;/span&gt;&lt;/a&gt;】那些喜欢“以身试毒”的人，我劝你别乱来，命只有一条&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[微笑]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_hehe-0be7e6251f.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。吃菌子，记好这4点：①不认识、不熟悉的不吃；②杂菌混煮的不吃；③霉变和太幼小的不吃；④饮酒时不吃。另外，烹饪野生菌一定要做熟，吃完出现不适，请立即就医！（央视新闻）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5033578212556881&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax2.sinaimg.cn/orj480/002TLsr9ly1hpnvl5pvwbj60ji0azqbj02.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/ou7DVRuAlx08eOXRhibS01041200Fj1H0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1715738365&amp;amp;ssig=ebwMzAbSPM&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/4YQueTtxlx08eOXQHhzy01041200myjl0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1715738365&amp;amp;ssig=mlOrdX4Gjc&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/Op6dmjZklx08eOXQF2UM01041200dShi0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1715738365&amp;amp;ssig=fawMv0Hk9L&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5033578212556881&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OeeTVgzFu</link><guid isPermaLink="false">https://weibo.com/2831150640/OeeTVgzFu</guid><pubDate>Tue, 14 May 2024 06:26:28 GMT</pubDate><author>深圳卫健委</author></item><item><title>【深圳市创伤救治临床研究中心成立[打call]】5月11日，深圳市创伤救治临床医学研究中心项目启动会顺利召开。研究中心由深圳大学总医院牵头，成员包括深圳市急救...</title><description>【深圳市创伤救治临床研究中心成立&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[打call]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/fb_a1dacall-1e0c4593fc.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;】5月11日，深圳市创伤救治临床医学研究中心项目启动会顺利召开。研究中心由深圳大学总医院牵头，成员包括深圳市急救中心、深圳市第二人民医院等50多家骨干单位，标志着深圳在创伤医学领域的进一步发展和突破。&lt;br&gt;&lt;br&gt;未来，研究中心将针对创伤救治领域进行深入研究，为深圳市民带来更及时、更专业、更有效的创伤救治服务。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[彩虹屁]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/4b/2022_praise_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%96%B0%E9%B2%9C%E4%BA%8B%E5%84%BF%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%96%B0%E9%B2%9C%E4%BA%8B%E5%84%BF%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫新鲜事儿#&lt;/span&gt;&lt;/a&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpoz4grki2j21vl0u0gyj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpoz4sym6fj21900u0aj5.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hpoz45pk41j21400u0k0l.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OeetOocLs</link><guid isPermaLink="false">https://weibo.com/2831150640/OeetOocLs</guid><pubDate>Tue, 14 May 2024 05:22:08 GMT</pubDate><author>深圳卫健委</author></item><item><title>[哆啦A梦害怕]#长期用吸管喝水可能会加深唇纹#？？是真的！[揣手]吸管喝水会牵动更多的面部肌肉和唇部肌肉，导致唇边和面部的纹路更深！如果实在喜欢用吸管喝水...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[哆啦A梦害怕]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/doraemon/dr_03haipa-32e9b53caf.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E9%95%BF%E6%9C%9F%E7%94%A8%E5%90%B8%E7%AE%A1%E5%96%9D%E6%B0%B4%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%8A%A0%E6%B7%B1%E5%94%87%E7%BA%B9%23&amp;amp;extparam=%23%E9%95%BF%E6%9C%9F%E7%94%A8%E5%90%B8%E7%AE%A1%E5%96%9D%E6%B0%B4%E5%8F%AF%E8%83%BD%E4%BC%9A%E5%8A%A0%E6%B7%B1%E5%94%87%E7%BA%B9%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#长期用吸管喝水可能会加深唇纹#&lt;/span&gt;&lt;/a&gt;？？&lt;br&gt;&lt;br&gt;是真的！&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[揣手]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/af/2022_chuaishou_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;吸管喝水会牵动更多的面部肌肉和唇部肌肉，导致唇边和面部的纹路更深！如果实在喜欢用吸管喝水，也不是不行，可以把吸管往嘴角放，这样操作牵动的肌肉更少，也能减少唇纹的产生。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（科普中国） &lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hpovpyussgg205k05kq3r.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OedHTyOUR</link><guid isPermaLink="false">https://weibo.com/2831150640/OedHTyOUR</guid><pubDate>Tue, 14 May 2024 03:24:05 GMT</pubDate><author>深圳卫健委</author></item><item><title>【🥵热热热！#夏季容易引发肾脏危机#】肾脏，俗称“腰子”，位于背部中下方的左右两侧。它默默承担着排除身体代谢废物、调节身体血压等生理功能。饮水不足会导...</title><description>【🥵热热热！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%A4%8F%E5%AD%A3%E5%AE%B9%E6%98%93%E5%BC%95%E5%8F%91%E8%82%BE%E8%84%8F%E5%8D%B1%E6%9C%BA%23&amp;amp;extparam=%23%E5%A4%8F%E5%AD%A3%E5%AE%B9%E6%98%93%E5%BC%95%E5%8F%91%E8%82%BE%E8%84%8F%E5%8D%B1%E6%9C%BA%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#夏季容易引发肾脏危机#&lt;/span&gt;&lt;/a&gt;】肾脏，俗称“腰子”，位于背部中下方的左右两侧。它默默承担着排除身体代谢废物、调节身体血压等生理功能。饮水不足会导致尿液浓缩，增加结石和感染的风险，尤其天气热，更要多喝水！但&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%96%9D%E6%B0%B4%E5%90%8E%E6%9C%894%E7%A7%8D%E8%A1%A8%E7%8E%B0%E6%98%AF%E8%82%BE%E8%84%8F%E5%9C%A8%E6%B1%82%E6%95%91%23&amp;amp;extparam=%23%E5%96%9D%E6%B0%B4%E5%90%8E%E6%9C%894%E7%A7%8D%E8%A1%A8%E7%8E%B0%E6%98%AF%E8%82%BE%E8%84%8F%E5%9C%A8%E6%B1%82%E6%95%91%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#喝水后有4种表现是肾脏在求救#&lt;/span&gt;&lt;/a&gt;👇🏻&lt;br&gt;&lt;br&gt;①脸部、四肢水肿：肾不好时，体液平衡容易出现异常，导致脸部、四肢出现水肿。&lt;br&gt;&lt;br&gt;②频繁起夜：夜间频繁如厕可能是肾脏功能减退，男性还要关注前列腺方面的疾病。&lt;br&gt;&lt;br&gt;③蛋白尿：就是我们平时说的“泡沫尿”，是因为肾小球滤过膜受损，导致尿液中析出了泡沫。&lt;br&gt;&lt;br&gt;④血压升高：肾脏不好，喝下去的水会囤积在血管内部，导致血压升高，吃了降压药也不能缓解。&lt;br&gt;&lt;br&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;《中国居民膳食指南（2022）》建议，成年男性每天适宜摄入1700毫升的水，成年女性适宜摄入1500毫升的水。另外，喝水建议少量多次，肾病、尿毒症等患者，则需遵医嘱，合理控制饮水量。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国）&lt;br&gt;&lt;br&gt;别等到肾功能受损才后悔&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hpougpsp6oj20ik0s1diz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpougpsvcgj20q61hewid.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hpougpoj6hj20cl0eo75b.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Oedqf2HvI</link><guid isPermaLink="false">https://weibo.com/2831150640/Oedqf2HvI</guid><pubDate>Tue, 14 May 2024 02:40:35 GMT</pubDate><author>深圳卫健委</author></item><item><title>叶菜和水果能在一起存放吗？？部分水果，比如苹果、香蕉、芒果、桃子等，在成熟时，会释放一种催熟的气体——乙烯。它会让蔬菜加速变黄、变老、失去营养价值。但...</title><description>叶菜和水果能在一起存放吗？？&lt;br&gt;&lt;br&gt;部分水果，比如苹果、香蕉、芒果、桃子等，在成熟时，会释放一种催熟的气体——乙烯。它会让蔬菜加速变黄、变老、失去营养价值。&lt;br&gt;&lt;br&gt;但水果却可以与根茎类作物，比如土豆、番薯、洋葱等蔬菜一起存放，因为乙烯反而抑制根茎作物发芽，延长它们的保质期。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（健康广东）&lt;br&gt;&lt;br&gt;一物降一物&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[awsl]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/fb_a3awsl-ed1a33c1b3.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpo2rkm7rhg20hs0a6he0.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Oe79fqy4n</link><guid isPermaLink="false">https://weibo.com/2831150640/Oe79fqy4n</guid><pubDate>Mon, 13 May 2024 10:42:15 GMT</pubDate><author>深圳卫健委</author></item><item><title>牛奶有丰富的优质蛋白和钙，可谓“男女老少通杀”。《中国居民膳食指南（2022）》建议，成人每日摄入奶及奶制品300克-500克，如果不喜欢喝牛奶，或乳糖不耐受的...</title><description>牛奶有丰富的优质蛋白和钙，可谓“男女老少通杀”。《中国居民膳食指南（2022）》建议，成人每日摄入奶及奶制品300克-500克，如果不喜欢喝牛奶，或乳糖不耐受的人，该怎么吃？学起来&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[馋嘴]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chanzui-fc1acc341b.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hpo01yibq4j20u05xwnl2.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hpo01xto3ij20u00ky0vz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Oe6xb3isv</link><guid isPermaLink="false">https://weibo.com/2831150640/Oe6xb3isv</guid><pubDate>Mon, 13 May 2024 09:08:27 GMT</pubDate><author>深圳卫健委</author></item></channel></rss>