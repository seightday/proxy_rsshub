0%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht77g7uc4nj20k00qogni.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht77g7yienj20k00qomye.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht77g82z8dj20k00qodh2.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1ht77g84whbj20k00qogmv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht77g7ynolj20k00qoabk.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht77g7wwarj20k00qoabn.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuPP6ck3x</link><guid isPermaLink="false">https://weibo.com/2831150640/OuPP6ck3x</guid><pubDate>Sat, 31 Aug 2024 09:51:04 GMT</pubDate><author>深圳卫健委</author><category>原来跳绳真的这么好瘦</category><category>小卫辟谣问答</category></item><item><title>【[圆月]中秋节新骗局出现！已有人中招！】近日，常州的小琴（化名）收到一个包裹，里面竟是一张领取洗衣液、现金等三重豪礼的“中秋礼品卡”！小琴扫描了礼品卡...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[圆月]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/cr_x3yy-e91c602942.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;中秋节新骗局出现！已有人中招！】近日，常州的小琴（化名）收到一个包裹，里面竟是一张领取洗衣液、现金等三重豪礼的“中秋礼品卡”！小琴扫描了礼品卡上二维码，加入了一个群聊，就开始“做任务”了。只要搜索歌曲，截图发群内，就能领取小额红包。然而，这仅仅是诈骗的开始......（深圳市反电信网络诈骗中心）👉🏻 &lt;a href=&quot;https://mp.weixin.qq.com/s/F0LiN5WpLViNkCk5nr0nFw&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_web_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;中秋节新骗局出现！已有人中招！&lt;/span&gt;&lt;/a&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht74lz046hj20u018yk2j.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuPbdbIuF</link><guid isPermaLink="false">https://weibo.com/2831150640/OuPbdbIuF</guid><pubDate>Sat, 31 Aug 2024 08:12:48 GMT</pubDate><author>深圳卫健委</author></item><item><title>[开学季]明天终于开！学！啦！水痘、流行性腮腺炎、猩红热又同时“杀到”，怎么远离它们？家长快学起👇🏻#小卫唠健康#（健康中国） [图片][图片]</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[开学季]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/72/2021_kaixueji_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;明天终于开！学！啦！水痘、流行性腮腺炎、猩红热又同时“杀到”，怎么远离它们？家长快学起👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1ht6x1fdrydj20m81v5gv3.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1ht6x1fbtjgj20u00wcgqt.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuNsTdK2e</link><guid isPermaLink="false">https://weibo.com/2831150640/OuNsTdK2e</guid><pubDate>Sat, 31 Aug 2024 03:50:52 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category></item><item><title>💉#打针前医生为何要推出部分药水# 打针前护士从针管里滋出一点药水的动作，简直是每个人的童年阴影[骷髅] 为啥要这样吓唬人啊？？其实，他们是怕——①怕你噶...</title><description>💉&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%89%93%E9%92%88%E5%89%8D%E5%8C%BB%E7%94%9F%E4%B8%BA%E4%BD%95%E8%A6%81%E6%8E%A8%E5%87%BA%E9%83%A8%E5%88%86%E8%8D%AF%E6%B0%B4%23&amp;amp;extparam=%23%E6%89%93%E9%92%88%E5%89%8D%E5%8C%BB%E7%94%9F%E4%B8%BA%E4%BD%95%E8%A6%81%E6%8E%A8%E5%87%BA%E9%83%A8%E5%88%86%E8%8D%AF%E6%B0%B4%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#打针前医生为何要推出部分药水#&lt;/span&gt;&lt;/a&gt; 打针前护士从针管里滋出一点药水的动作，简直是每个人的童年阴影&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[骷髅]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_kulou-116c59c096.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; 为啥要这样吓唬人啊？？其实，他们是怕——&lt;br&gt;&lt;br&gt;①怕你噶了&lt;br&gt;&lt;br&gt;在抽药水时，难免会有空气进入，如果是皮下注射，进了点空气，影响不大。可静脉注射就不一样了，如果空气进入血管，又碰到较细的血管，就会把路堵着，影响血液流动。&lt;br&gt;&lt;br&gt;②怕你疼&lt;br&gt;&lt;br&gt; 直接注射，药水压力突然改变，注射部位的压力会加大。先滋掉一点药水，疏通针管，让内外压强一样，你就没那么疼。&lt;br&gt;&lt;br&gt;别小看这一丢丢压力的改变，打在你身上，差别就不是一丢丢了……&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;③怕给你打多了&lt;br&gt;&lt;br&gt;技术再熟练的医护人员，也不可能一次就抽到准确剂量的药水，所以一般都会采用“加量不加价”的装罐方式。&lt;br&gt;&lt;br&gt;根据《中国药典（2020版）》规定，小于50ml的罐装注射剂，可以比瓶身标注的剂量，多装那么零点几毫升。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;br&gt;&lt;br&gt;所以，别怪他们了，都是为你好&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[喵喵]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_miao-c1b3d563bd.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1ht6t1v8o10j20b30bz74w.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1ht6t1vfz8pj20dj0e5gmk.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht6t1vbj0oj20r50ktabh.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuMyT34IT</link><guid isPermaLink="false">https://weibo.com/2831150640/OuMyT34IT</guid><pubDate>Sat, 31 Aug 2024 01:32:53 GMT</pubDate><author>深圳卫健委</author><category>打针前医生为何要推出部分药水</category><category>小卫辟谣问答</category></item><item><title>【[话筒]爸妈注意！孩子1岁还不会牙牙学语，要警惕孤独症】医生介绍，孩子出现以下情况，应尽早就医评估筛查：①1岁左右还不会牙牙学语；②回避眼神交流；③听力...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;爸妈注意！孩子1岁还不会牙牙学语，要警惕孤独症】医生介绍，孩子出现以下情况，应尽早就医评估筛查：①1岁左右还不会牙牙学语；②回避眼神交流；③听力没问题，但与其说话没有反应；④玩玩具、摆放物品时总按固定模式进行。目前，暂时没有药物可以治疗，越早发现干预，效果越好，宝爸宝妈一定要及时关注&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[许愿星]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/a8/2022_WishingStar_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; &lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（央视新闻）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5018664530018345&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax3.sinaimg.cn/orj480/002TLsr9ly1hocasdd8r9j60vq16a7wh02.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/PqQsTGoblx08dLk4qiHm01041200qa7U0E010.mp4?label=mp4_720p&amp;amp;template=720x1280.24.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1725154882&amp;amp;ssig=f2qBYw9uOR&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/PZqQwS2Qlx08dLk4h8eY01041200fhNA0E010.mp4?label=mp4_hd&amp;amp;template=540x960.24.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1725154882&amp;amp;ssig=kZS5VMo2Qk&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/RmP0gG3Ulx08dLk402QE010412008p4b0E010.mp4?label=mp4_ld&amp;amp;template=360x640.24.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1725154882&amp;amp;ssig=pceA4h2cte&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5018664530018345&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OuHrOpqFx</link><guid isPermaLink="false">https://weibo.com/2831150640/OuHrOpqFx</guid><pubDate>Fri, 30 Aug 2024 12:31:44 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category></item><item><title>🍌香蕉可以空腹吃吗？只要你的肾脏健康，完全不用担心。有人说：空腹吃香蕉，会让人体中的镁暴增，破坏血液中的镁钙平衡，不利于心血管和身体健康......香蕉的...</title><description>🍌香蕉可以空腹吃吗？&lt;br&gt;&lt;br&gt;只要你的肾脏健康，完全不用担心。&lt;br&gt;&lt;br&gt;有人说：空腹吃香蕉，会让人体中的镁暴增，破坏血液中的镁钙平衡，不利于心血管和身体健康......&lt;br&gt;&lt;br&gt;香蕉的钾、镁含量确实比较高，但就算真空腹吃了，它所含的钾、镁，也是慢慢进入体内的，吸收量有限，不会一下子全部进入血液。&lt;br&gt;&lt;br&gt;而且，我们的身体没那么脆弱，它会自行调节，通过肾脏、皮肤，把多余的部分代谢出去，维持钾、镁处于平衡状态。&lt;br&gt;&lt;br&gt;所以，对于肾脏健康的人来说，每天钾、镁的摄入并没有严格的上限哦&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; &lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东疾控）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht629clwkng20at06m1ky.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuGuCwsGX</link><guid isPermaLink="false">https://weibo.com/2831150640/OuGuCwsGX</guid><pubDate>Fri, 30 Aug 2024 10:05:54 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>🥵大热天的，皮肤还需要保湿吗？要！再说了，你搁空调房里搬砖，室外再热，和你一点关系都没有[doge]。皮肤屏障，是皮肤最外层的角质层，由水、油脂、脱落的表...</title><description>🥵大热天的，皮肤还需要保湿吗？&lt;br&gt;&lt;br&gt;要！再说了，你搁空调房里搬砖，室外再热，和你一点关系都没有&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。&lt;br&gt;&lt;br&gt;皮肤屏障，是皮肤最外层的角质层，由水、油脂、脱落的表皮细胞、正常的菌群等构成。如果皮肤屏障受损，会引起红斑、毛细血管扩张、紧绷、干燥等，甚至可能出现皮肤敏感状态，尤其是干性皮肤的宝。&lt;br&gt;&lt;br&gt;对于长期待在空调房里的人，保湿可太重要了！当室内空气逐渐变得干燥，我们皮肤上的水分，会被“吸”到空气中。表皮的水分一旦被吸光，就吸更深层的水分，直到你的皮肤出现紧绷、瘙痒、皮肤屏障受损。&lt;br&gt;&lt;br&gt;另外，长时间吹空调，汗液就分泌得少，皮肤一缺水，弹性自然会变差。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国）&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1ht60cq8ahkj20u00nqtbv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1ht60cq9tspj20u00gsmy8.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuG3R2zVo</link><guid isPermaLink="false">https://weibo.com/2831150640/OuG3R2zVo</guid><pubDate>Fri, 30 Aug 2024 08:59:57 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>#你知道子宫有多大吗#一个成年女性的子宫体积，大约为 7 × 4 × 2 cm，和鸡蛋差不多大小。怀孕后，它会慢慢长大，最终长到西瓜大小，是原来的近300倍！表面看来，...</title><description>&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E4%BD%A0%E7%9F%A5%E9%81%93%E5%AD%90%E5%AE%AB%E6%9C%89%E5%A4%9A%E5%A4%A7%E5%90%97%23&amp;amp;extparam=%23%E4%BD%A0%E7%9F%A5%E9%81%93%E5%AD%90%E5%AE%AB%E6%9C%89%E5%A4%9A%E5%A4%A7%E5%90%97%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#你知道子宫有多大吗#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;一个成年女性的子宫体积，大约为 7 × 4 × 2 cm，和鸡蛋差不多大小。怀孕后，它会慢慢长大，最终长到西瓜大小，是原来的近300倍！&lt;br&gt;&lt;br&gt;表面看来，孕妈妈只是肚子大了，但实际上，身体里的五脏六腑，都会被增大的子宫挤压、并不断为它腾出空间。&lt;br&gt;&lt;br&gt;所以，怀孕从来就不是一件轻松的事。&lt;br&gt;&lt;br&gt;最后，再分享一张图，愿所有的妈妈都能被温柔以待&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[许愿星]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/a8/2022_WishingStar_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht5xzadlfjg205a06ox6p.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuFwwps6l</link><guid isPermaLink="false">https://weibo.com/2831150640/OuFwwps6l</guid><pubDate>Fri, 30 Aug 2024 07:37:50 GMT</pubDate><author>深圳卫健委</author><category>你知道子宫有多大吗</category><category>小卫辟谣问答</category></item><item><title>[馋嘴]酸奶要放冷藏，还是冷冻？酸奶经过发酵，蛋白质凝固、乳糖变为乳酸、游离氨基酸和肽增加，不仅营养价值更高、更容易被人体消化吸收，叶酸含量也增加了1倍...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[馋嘴]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chanzui-fc1acc341b.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;酸奶要放冷藏，还是冷冻？&lt;br&gt;&lt;br&gt;酸奶经过发酵，蛋白质凝固、乳糖变为乳酸、游离氨基酸和肽增加，不仅营养价值更高、更容易被人体消化吸收，叶酸含量也增加了1倍。&lt;br&gt;&lt;br&gt;但酸奶一旦冷冻，蛋白质和其他营养成分，会发生变性、遭受损失。所以，酸奶放冷藏就好啦。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht5xsw832zj20p00fbq53.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuFu29Dhk</link><guid isPermaLink="false">https://weibo.com/2831150640/OuFu29Dhk</guid><pubDate>Fri, 30 Aug 2024 07:31:41 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>【[吃惊]30岁女子直播间购买胶原蛋白，吃后肝损伤，被下病重通知书！】这天，年过30的小倩（化名）看直播时，被安利了一款“能让皮肤Q弹饱满，重回少女”的胶原...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;30岁女子直播间购买胶原蛋白，吃后肝损伤，被下病重通知书！】这天，年过30的小倩（化名）看直播时，被安利了一款“能让皮肤Q弹饱满，重回少女”的胶原蛋白，下单后，她就乖乖按照主播说的，每天睡前喝一支。&lt;br&gt;&lt;br&gt;坚持了两个月后，小倩开始浑身无力，食欲不振，不仅皮肤越来越黄，小便还变成了浓茶色！她吓坏了，火速前往附近的医院。&lt;br&gt;&lt;br&gt;做完检查后，小倩慌了，肝功能显示——&lt;br&gt;&lt;br&gt;①转氨酶1000+U/L（正常值为10-40U/L）。&lt;br&gt;②黄疸，胆红素146umol/L（正常值为0-20umol/L）&lt;br&gt;&lt;br&gt;由于病情较严重，医生建议她转深圳市第三人民医院继续治疗。&lt;br&gt;&lt;br&gt;肝炎肝硬化科进一步完善检查后，马上就下达了病重通知书。虽然她只是表面看着浑身发黄，实际上肝功能已经严重损伤，凝血功能也出现障碍，病情随时可能继续恶化！&lt;br&gt;&lt;br&gt;主治医师赖长祥详细询问小倩的病史，逐一排除病因。最后，医生将目光锁定在“药物性肝损伤”。小倩立刻向医生说明，自己确实吃了两个月某品牌的胶原蛋白。&lt;br&gt;&lt;br&gt;我们吃下去的药物，有90%都要在肝脏中代谢。乱吃药、成分不明的保健品，或服药的剂量不对，都会加重肝脏的负担，增加肝脏受损的风险。严重时，甚至会肝衰竭，危及生命。&lt;br&gt;&lt;br&gt;另外，胶原蛋白存在于我们的皮肤、软骨等组织里，可以维持皮肤弹性，防止皱纹形成。但它很难通过口服补充，姐妹们别再上当了。&lt;br&gt;&lt;br&gt;经过10余天的治疗后，小倩的肝功能已逐渐恢复，目前，已经出院回家，继续服药调养。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫说案例#&lt;/span&gt;&lt;/a&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%A5%B3%E5%AD%90%E7%9B%B4%E6%92%AD%E9%97%B4%E4%B9%B0%E8%83%B6%E5%8E%9F%E8%9B%8B%E7%99%BD%E5%90%83%E5%90%8E%E8%82%9D%E8%A1%B0%E7%AB%AD%23&amp;amp;extparam=%23%E5%A5%B3%E5%AD%90%E7%9B%B4%E6%92%AD%E9%97%B4%E4%B9%B0%E8%83%B6%E5%8E%9F%E8%9B%8B%E7%99%BD%E5%90%83%E5%90%8E%E8%82%9D%E8%A1%B0%E7%AB%AD%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#女子直播间买胶原蛋白吃后肝衰竭#&lt;/span&gt;&lt;/a&gt;（深圳市第三人民医院）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht5ugjjxhgj20mj0gymz4.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1ht5ugj6a8vj20ov0h8mzu.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1ht5ugj60htj20sl0awaak.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OuEJ5g3ho</link><guid isPermaLink="false">https://weibo.com/2831150640/OuEJ5g3ho</guid><pubDate>Fri, 30 Aug 2024 05:36:01 GMT</pubDate><author>深圳卫健委</author><category>小卫说案例</category><category>女子直播间买胶原蛋白吃后肝衰竭</category></item></channel></rss>