%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东疾控、深圳疾控）&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hsxtd9o24oj20rk0xgq7c.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hsxtda7g03j20u00ysgqu.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hsxtd9s9y7j20rg0m840z.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OtBfanZUi</link><guid isPermaLink="false">https://weibo.com/2831150640/OtBfanZUi</guid><pubDate>Fri, 23 Aug 2024 06:53:47 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>【50岁阿姨肚大像足月孕妇，医生“剥”出26斤大包块[衰]】李阿姨今年50岁。4年前，她发现自己的肚子越来越大，以为是更年期发胖，也就没想这么多。可随着时间的...</title><description>【50岁阿姨肚大像足月孕妇，医生“剥”出26斤大包块&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[衰]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_shuai-285d2d97c7.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;】李阿姨今年50岁。4年前，她发现自己的肚子越来越大，以为是更年期发胖，也就没想这么多。可随着时间的推移，这肚子竟“膨胀”到像快临盆的孕妈妈的肚子大小！&lt;br&gt;&lt;br&gt;四处打听后，李阿姨来到深圳市妇幼保健院。经过妇科主任祝文峰的全面检查，以及多科室MDT会诊讨论，结果让所有人都吓一大跳！&lt;br&gt;&lt;br&gt;医生们发现，李阿姨肚子里的巨大包块，可能来自右侧卵巢囊腺瘤，大小竟达42.3cm×25.5cm×13.9cm，左右两边都到腹中线了！而且，包块已经压迫了腹腔内的多个脏器，必须尽快手术！&lt;br&gt;&lt;br&gt;考虑到李阿姨不想留疤，医生们经过讨论，决定为她进行“经脐单孔腹腔镜微创手术”。手术由副主任医师史文娟、彭欣韵医生主刀。&lt;br&gt;&lt;br&gt;术中，这个巨大包块的“真面目”终于藏不住了，它几乎占据了整个肚子，导致可操作的空间非常小。手术团队思考了一会儿，决定：抽水！&lt;br&gt;&lt;br&gt;医生们一边保护好周围组织，一边小心地慢慢吸出包块里的囊液，包块体积瞬间变小。&lt;br&gt;&lt;br&gt;2个小时后，这颗巨大肿瘤终于被顺利“剥”下，术中抽取了14000ml囊液，出血仅20ml。&lt;br&gt;&lt;br&gt;术后第二天，李阿姨的体重减轻了26斤，她笑着说：“自己好像卸了一个‘重担’。”&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫说案例#&lt;/span&gt;&lt;/a&gt;（深圳市妇幼保健院）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hsxr7l551cj20tr0trdii.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hsxr7l687rj20hw0hwjss.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hsxr7l6yqaj20u00u0qa4.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hsxr7l5szbj20mj0mi0uh.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OtAKQFWZ1</link><guid isPermaLink="false">https://weibo.com/2831150640/OtAKQFWZ1</guid><pubDate>Fri, 23 Aug 2024 05:39:06 GMT</pubDate><author>深圳卫健委</author><category>小卫说案例</category></item><item><title>【[话筒]#未成年人整容易致面部比例失调#】暑假期间，医疗机构涌入大量未成年人咨询五花八门的整容项目，从割双眼皮、隆鼻，到风险极高的削切下颌角等，年龄最小...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%9C%AA%E6%88%90%E5%B9%B4%E4%BA%BA%E6%95%B4%E5%AE%B9%E6%98%93%E8%87%B4%E9%9D%A2%E9%83%A8%E6%AF%94%E4%BE%8B%E5%A4%B1%E8%B0%83%23&amp;amp;extparam=%23%E6%9C%AA%E6%88%90%E5%B9%B4%E4%BA%BA%E6%95%B4%E5%AE%B9%E6%98%93%E8%87%B4%E9%9D%A2%E9%83%A8%E6%AF%94%E4%BE%8B%E5%A4%B1%E8%B0%83%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#未成年人整容易致面部比例失调#&lt;/span&gt;&lt;/a&gt;】暑假期间，医疗机构涌入大量未成年人咨询五花八门的整容项目，从割双眼皮、隆鼻，到风险极高的削切下颌角等，年龄最小的，只有11岁！更离谱的是，甚至有&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%9C%AA%E6%88%90%E5%B9%B4%E5%A5%B3%E7%94%9F%E6%89%BE%E4%BA%BA%E5%86%92%E5%85%85%E7%88%B6%E6%AF%8D%E5%90%8C%E6%84%8F%E6%95%B4%E5%AE%B9%23&amp;amp;extparam=%23%E6%9C%AA%E6%88%90%E5%B9%B4%E5%A5%B3%E7%94%9F%E6%89%BE%E4%BA%BA%E5%86%92%E5%85%85%E7%88%B6%E6%AF%8D%E5%90%8C%E6%84%8F%E6%95%B4%E5%AE%B9%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#未成年女生找人冒充父母同意整容#&lt;/span&gt;&lt;/a&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; 医生提醒，未成年人面部骨骼和肌肉发育还不完全，过早整容会影响软组织发育，导致面部比例失调。以更加美观为目的的整容手术要在16岁以后、家长陪同下进行；涉及到面部骨骼类的医疗美容手术建议在18岁以后、生长发育完成后再考虑。而影响生理功能的面部缺陷，如倒睫、唇腭裂等，则应尽早手术。 （央视新闻）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5070430579654669&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax1.sinaimg.cn/orj480/002TLsr9ly1hsxg0wwhc7j60t30gd7e802.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/9S11bHwNlx08hrb98bHW01041200SQqB0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1Cx9YB1mmR49jS&amp;amp;Expires=1724402850&amp;amp;ssig=RRiLhctYuq&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/Khx6H7pDlx08hrb8svTq01041200svG70E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1Cx9YB1mmR49jS&amp;amp;Expires=1724402850&amp;amp;ssig=o0mvIuBy%2FY&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/Moo1aLKglx08hrb8nNl601041200hV9V0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1Cx9YB1mmR49jS&amp;amp;Expires=1724402850&amp;amp;ssig=Dep4nTIwxZ&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5070430579654669&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OtzSfg5CQ</link><guid isPermaLink="false">https://weibo.com/2831150640/OtzSfg5CQ</guid><pubDate>Fri, 23 Aug 2024 03:24:33 GMT</pubDate><author>深圳卫健委</author><category>未成年人整容易致面部比例失调</category><category>未成年女生找人冒充父母同意整容</category></item><item><title>🍂一入秋，有过敏性鼻炎的人，苦日子就来了。喷嚏狂打、鼻涕狂流、鼻子痒、鼻塞......这份“保命”建议，都跟我狠狠记住！别以为深圳“入秋失败”，就不会“秋...</title><description>🍂一入秋，有过敏性鼻炎的人，苦日子就来了。喷嚏狂打、鼻涕狂流、鼻子痒、鼻塞......这份“保命”建议，都跟我狠狠记住！别以为深圳“入秋失败”，就不会“秋季过敏”👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hsxlkoj7s7j20k00qotb1.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hsxlkolfjjj20k00qodhq.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hsxlkok5g2j20k00qomyx.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hsxlkol62lj20k00qogmj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hsxlkom2e5j20k00qodhj.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hsxlkokuwcj20k00qoq3y.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hsxlkopnwxj20k00qozlm.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hsxlkorra9j20k00qo0tv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OtztHsXty</link><guid isPermaLink="false">https://weibo.com/2831150640/OtztHsXty</guid><pubDate>Fri, 23 Aug 2024 02:24:06 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category></item><item><title>你们的枕芯，多久没洗了？[吐]多项研究发现，枕头里的尘螨，平均浓度可能比地毯高出十几倍，甚至二十倍！你想啊，你每天睡觉流的口水、从头皮上掉进去的皮脂皮屑...</title><description>你们的枕芯，多久没洗了？&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吐]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_tu-cfbe704573.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;多项研究发现，枕头里的尘螨，平均浓度可能比地毯高出十几倍，甚至二十倍！你想啊，你每天睡觉流的口水、从头皮上掉进去的皮脂皮屑、头发，都是尘螨爱吃的……&lt;br&gt;&lt;br&gt;尘螨，是出了名的“过敏原之王”，它们繁殖超快！残留的尸体、粪便、卵和脱落下的皮壳，一旦被你吸入，就可能导致过敏。&lt;br&gt;&lt;br&gt;所以啊，阿卫建议，购买枕芯时，最好优先选择可清洗的枕芯(化纤、硅胶等材质)，而且，至少每3个月就清洗1次或充分暴晒。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东疾控、深圳市儿童医院）&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hswx5dje1vg20go0b47wh.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hswx5difrej20hs0ejq3w.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OttWG4phl</link><guid isPermaLink="false">https://weibo.com/2831150640/OttWG4phl</guid><pubDate>Thu, 22 Aug 2024 12:19:00 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>👶🏻宝宝被蚊虫叮咬，可以涂抹风油精止痒吗？最好不要！风油精的主要成分有薄荷脑、水杨酸甲酯、樟脑、桉油等，它能止痛、止痒、缓解蚊虫叮咬、晕车等情况。...</title><description>👶🏻宝宝被蚊虫叮咬，可以涂抹风油精止痒吗？&lt;br&gt;&lt;br&gt;最好不要！风油精的主要成分有薄荷脑、水杨酸甲酯、樟脑、桉油等，它能止痛、止痒、缓解蚊虫叮咬、晕车等情况。&lt;br&gt;&lt;br&gt;但是，水杨酸甲酯有较高的急性毒性，涂抹在婴幼儿身上，容易有误食风险。另外，它可能对胎儿有不良影响，孕妇也应该避免使用。&lt;br&gt;&lt;br&gt;不止风油精，无比滴、花露水、清凉油等，也不适合让婴幼儿使用。&lt;br&gt;&lt;br&gt;如果家中宝宝被蚊虫叮咬了，可以涂抹炉甘石洗剂。它的成分安全，世卫组织已将它列入了儿童基本用药清单，而且，孕妇也能放心使用&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[开学季]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/72/2021_kaixueji_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东药监）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hswsxthmrij20r72ajtep.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hswsxth5jpj20u00kntb2.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hswsxthqgxj20u00l1dhg.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OtsZyttpR</link><guid isPermaLink="false">https://weibo.com/2831150640/OtsZyttpR</guid><pubDate>Thu, 22 Aug 2024 09:53:21 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>【[话筒]提醒！#溺水后倒挂控水不可取#】很多人认为，溺水者喝多了水，倒挂着把水倒出来就行。[话筒]医生提醒：千万不可！倒挂改善不了溺水者的缺氧状态，反而会...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;提醒！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%BA%BA%E6%B0%B4%E5%90%8E%E5%80%92%E6%8C%82%E6%8E%A7%E6%B0%B4%E4%B8%8D%E5%8F%AF%E5%8F%96%23&amp;amp;extparam=%23%E6%BA%BA%E6%B0%B4%E5%90%8E%E5%80%92%E6%8C%82%E6%8E%A7%E6%B0%B4%E4%B8%8D%E5%8F%AF%E5%8F%96%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#溺水后倒挂控水不可取#&lt;/span&gt;&lt;/a&gt;】很多人认为，溺水者喝多了水，倒挂着把水倒出来就行。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;医生提醒：千万不可！倒挂改善不了溺水者的缺氧状态，反而会耽误救援时间。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%BA%BA%E6%B0%B4%E5%90%8E%E5%A6%82%E4%BD%95%E5%AE%89%E5%85%A8%E6%96%BD%E6%95%91%23&amp;amp;extparam=%23%E6%BA%BA%E6%B0%B4%E5%90%8E%E5%A6%82%E4%BD%95%E5%AE%89%E5%85%A8%E6%96%BD%E6%95%91%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#溺水后如何安全施救#&lt;/span&gt;&lt;/a&gt;如果溺水者神志不清、没有呼吸，说明可能出现心搏骤停，正确操作是立即进行心肺复苏，同时打120👇🏻（央视新闻）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5070161598939157&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax3.sinaimg.cn/orj480/002TLsr9ly1hswl4tb4cbj6216156qv502.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/x0b2ocxslx08hpZ1DBHi01041201tL2y0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1724402883&amp;amp;ssig=FVBiQP3sCo&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/F9xO4bQilx08hpZ07aju01041200MYdE0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1724402883&amp;amp;ssig=cb%2B8%2B%2Bgzz5&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/COTtt5LVlx08hpYZaG1201041200tOVD0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1724402883&amp;amp;ssig=6e1JcLJJFD&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5070161598939157&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OtssUlcTx</link><guid isPermaLink="false">https://weibo.com/2831150640/OtssUlcTx</guid><pubDate>Thu, 22 Aug 2024 08:32:55 GMT</pubDate><author>深圳卫健委</author><category>溺水后倒挂控水不可取</category><category>溺水后如何安全施救</category></item><item><title>到点摸鱼，🐴牛马必看！在工位做这个动作，既能预防静脉曲张，又能锻炼小腿内侧腓肠肌，促进腿部血液循环。每个动作坚持5秒，重复5次，赶紧码走👇🏻#小卫...</title><description>到点摸鱼，🐴牛马必看！在工位做这个动作，既能预防静脉曲张，又能锻炼小腿内侧腓肠肌，促进腿部血液循环。每个动作坚持5秒，重复5次，赶紧码走👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（科普中国） &lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hswoy0e5mlg20gk09b1ky.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hswoy0xegeg20gk09b1ky.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Ots5suLht</link><guid isPermaLink="false">https://weibo.com/2831150640/Ots5suLht</guid><pubDate>Thu, 22 Aug 2024 07:35:09 GMT</pubDate><author>深圳卫健委</author><category>小卫唠健康</category></item><item><title>【[二哈]10岁娃眼睛被撞伤不当回事，3天后，眼内发炎险失明！】小胡（化名）今年10岁。这天，他解鞋带时，手一滑，脱手的鞋带尖端，不小心弹到右眼。当时，他只...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[二哈]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_erha-139d0e07bd.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;10岁娃眼睛被撞伤不当回事，3天后，眼内发炎险失明！】小胡（化名）今年10岁。这天，他解鞋带时，手一滑，脱手的鞋带尖端，不小心弹到右眼。当时，他只觉得眼睛很疼，还一直流泪。症状缓解后，他也没放在心上。&lt;br&gt;&lt;br&gt;第二天，小胡觉得右眼看东西有点儿模糊，滴了眼药水也没用。&lt;br&gt;&lt;br&gt;第三天，他的右眼已经完全看不清了，而且外观已经发白。当地医院建议，最好尽快转到上级医院。&lt;br&gt;&lt;br&gt;深圳市眼科医院医生检查后发现，小胡的右眼已经发展为严重的前房积脓，还感染了化脓性眼内炎（图2）。此外，他的角膜上还有一个3mm的全层裂伤口，医院马上为他安排了抗炎和急诊手术。&lt;br&gt;&lt;br&gt;无独有偶，10岁的小石（化名）被座椅的椅背撞伤左眼。3天后，爸妈发现他左眼眼白长了一个黑色肿物（图3），深圳市眼科医院检查后发现，他左眼鼻下方有一个约3mm的角膜全层裂伤。&lt;br&gt;&lt;br&gt;黑色肿物是角膜伤口脱出的虹膜组织，由于虹膜变形，小石的瞳孔已经变成了不规则的椭圆形。&lt;br&gt;&lt;br&gt;经过急诊手术和全身抗炎、抗感染治疗，小石的病情正在好转中。&lt;br&gt;&lt;br&gt;眼内炎不仅凶险，发展还特别迅猛，炎症产生的毒素和蛋白分解酶，会严重破坏眼内组织、损伤视功能。如果治疗不及时，严重时可能会发展为全眼球炎、眼球萎缩，甚至摘除眼球！&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;小卫提醒，孩子打闹嬉戏碰伤眼睛时，爸妈一定要警惕！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫说案例#&lt;/span&gt;&lt;/a&gt;（深圳市眼科医院）&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hswmw8k96yj20h80euq3j.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hswmw8k27ij20h10h10ta.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hswmw8jooxj20aj0ajwfb.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OtrCG5GL3</link><guid isPermaLink="false">https://weibo.com/2831150640/OtrCG5GL3</guid><pubDate>Thu, 22 Aug 2024 06:24:14 GMT</pubDate><author>深圳卫健委</author><category>小卫说案例</category></item></channel></rss>