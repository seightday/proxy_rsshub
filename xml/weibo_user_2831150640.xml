GtiLm0104120091L30E010.mp4?label=mp4_hd&amp;amp;template=540x960.24.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=EA1CeZV7tD&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/xUTi0dbZlx08iXSGB1te0104120057vn0E010.mp4?label=mp4_ld&amp;amp;template=360x640.24.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=e6Sgg2az53&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5091948315476011&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OCK7FsQzN</link><guid isPermaLink="false">https://weibo.com/2831150640/OCK7FsQzN</guid><pubDate>Tue, 22 Oct 2024 10:02:46 GMT</pubDate><author>深圳卫健委</author><category>发际线上移就说明是脱发吗</category><category>小卫辟谣问答</category></item><item><title>[委屈]#今天国际口吃日# 口吃，俗称“结巴”，是一种言语流畅性障碍。它被医学界认为是世界上最奇怪、最复杂的疾病之一。这病简单来说，就是你明确知道自己想要...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[委屈]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_weiqu-758386fa64.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E4%BB%8A%E5%A4%A9%E5%9B%BD%E9%99%85%E5%8F%A3%E5%90%83%E6%97%A5%23&amp;amp;extparam=%23%E4%BB%8A%E5%A4%A9%E5%9B%BD%E9%99%85%E5%8F%A3%E5%90%83%E6%97%A5%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#今天国际口吃日#&lt;/span&gt;&lt;/a&gt; 口吃，俗称“结巴”，是一种言语流畅性障碍。它被医学界认为是世界上最奇怪、最复杂的疾病之一。&lt;br&gt;&lt;br&gt;这病简单来说，就是你明确知道自己想要表达什么，却没办法完整、流畅地说出口。&lt;br&gt;&lt;br&gt;口吃在儿童中较为常见。数据显示，全球有约5%的儿童会出现口吃，其中，有约1%的人会持续到成年。&lt;br&gt;&lt;br&gt;口吃虽然不会直接损害健康，但可能会让孩子产生自卑心理，影响以后正常的工作、生活等。&lt;br&gt;&lt;br&gt;所以，你家娃说话时，如果出现字句重复、中断、不流利，或出现脸红、胸闷、喉舌僵硬、清喉咙、眨眼等异常行为，并持续半年以上，一定要尽早干预和治疗。&lt;br&gt;&lt;br&gt;治疗期间，家长一定要多点耐心、鼓励、夸奖，为孩子建立自信，陪他们一起克服困难&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[抱一抱]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/co_a1hug-f3910d0e88.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[拳头]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/h_quantou-81f684d5ed.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1huv9dv7riqj20rs0ku41x.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCJwMrS7c</link><guid isPermaLink="false">https://weibo.com/2831150640/OCJwMrS7c</guid><pubDate>Tue, 22 Oct 2024 08:31:54 GMT</pubDate><author>深圳卫健委</author><category>今天国际口吃日</category><category>小卫辟谣问答</category></item><item><title>🛌#睡觉有这个习惯的人老得更快#研究表示，与睡眠习惯稳定的人相比，时间偏差较大的入睡方式，比如昨天10点睡，今天12点睡，明天熬到2点，不仅生物年龄相差了9...</title><description>🛌&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E7%9D%A1%E8%A7%89%E6%9C%89%E8%BF%99%E4%B8%AA%E4%B9%A0%E6%83%AF%E7%9A%84%E4%BA%BA%E8%80%81%E5%BE%97%E6%9B%B4%E5%BF%AB%23&amp;amp;extparam=%23%E7%9D%A1%E8%A7%89%E6%9C%89%E8%BF%99%E4%B8%AA%E4%B9%A0%E6%83%AF%E7%9A%84%E4%BA%BA%E8%80%81%E5%BE%97%E6%9B%B4%E5%BF%AB%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#睡觉有这个习惯的人老得更快#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;研究表示，与睡眠习惯稳定的人相比，时间偏差较大的入睡方式，比如昨天10点睡，今天12点睡，明天熬到2点，不仅生物年龄相差了9个月，而且患痴呆风险会上升！&lt;br&gt;&lt;br&gt;所以，最好保证每天的入睡时间、起床时间都差不多，才能更好地保护大脑，延缓衰老。规律睡眠，做好7件事——&lt;br&gt;&lt;br&gt;①睡前不剧烈运动，避免大脑过度兴奋，分泌相关激素，影响睡眠质量。&lt;br&gt;&lt;br&gt;②睡前不吃高糖、高碳水的食物，避免血糖升高让人兴奋，不易入睡。&lt;br&gt;&lt;br&gt;③睡前尽量不玩手机。&lt;br&gt;&lt;br&gt;④睡前不说太多话，避免大脑兴奋、思维活跃，导致睡不着。&lt;br&gt;&lt;br&gt;⑤睡前不过度用脑。&lt;br&gt;&lt;br&gt;⑥睡前情绪不要激动，避免引起神经中枢兴奋或紊乱，难以入睡。&lt;br&gt;&lt;br&gt;⑦睡前不喝浓茶、咖啡，避免被其含有的咖啡影响睡眠。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东疾控）&lt;br&gt;&lt;br&gt;早点睡&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[哈欠]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_dahaqi-b1824d3d83.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1huv7i4a8h7j20mw08nmy5.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1huv7i4a5jbj20rz0gidhz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1huv7i4a3nhj20hs0eg3zm.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCJ6m8SHM</link><guid isPermaLink="false">https://weibo.com/2831150640/OCJ6m8SHM</guid><pubDate>Tue, 22 Oct 2024 07:26:47 GMT</pubDate><author>深圳卫健委</author><category>睡觉有这个习惯的人老得更快</category><category>小卫辟谣问答</category></item><item><title>【警惕！#长期忍受疼痛免疫力会降低#】疼痛已成为继心脑血管疾病、肿瘤之后的第三大健康问题！常见慢性疼痛包括长期颈肩腰腿痛、带状疱疹后神经痛、三叉神经痛等...</title><description>【警惕！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E9%95%BF%E6%9C%9F%E5%BF%8D%E5%8F%97%E7%96%BC%E7%97%9B%E5%85%8D%E7%96%AB%E5%8A%9B%E4%BC%9A%E9%99%8D%E4%BD%8E%23&amp;amp;extparam=%23%E9%95%BF%E6%9C%9F%E5%BF%8D%E5%8F%97%E7%96%BC%E7%97%9B%E5%85%8D%E7%96%AB%E5%8A%9B%E4%BC%9A%E9%99%8D%E4%BD%8E%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#长期忍受疼痛免疫力会降低#&lt;/span&gt;&lt;/a&gt;】疼痛已成为继心脑血管疾病、肿瘤之后的第三大健康问题！常见慢性疼痛包括长期颈肩腰腿痛、带状疱疹后神经痛、三叉神经痛等等，可很多人都是：①&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%BA%AB%E4%BD%93%E7%96%BC%E7%97%9B%E4%B8%8D%E6%98%AF%E5%BF%8D%E5%BF%8D%E5%B0%B1%E8%BF%87%E5%8E%BB%E4%BA%86%23&amp;amp;extparam=%23%E8%BA%AB%E4%BD%93%E7%96%BC%E7%97%9B%E4%B8%8D%E6%98%AF%E5%BF%8D%E5%BF%8D%E5%B0%B1%E8%BF%87%E5%8E%BB%E4%BA%86%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#身体疼痛不是忍忍就过去了#&lt;/span&gt;&lt;/a&gt;，研究证明，长期忍受疼痛折磨的人，免疫力会降低，引起其它疾病；②不是所有疼痛都能靠止痛药缓解，疼痛程度较重或部位发生变化，要及时就医。（央视新闻） &lt;a href=&quot;https://video.weibo.com/show?fid=1034:5091972214358030&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;央视新闻的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax4.sinaimg.cn/orj480/002TLsr9ly1huu62c7t6sj61nc0xdb2902.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/fLkxvUqzlx08iXYLJgY001041200A7Td0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=%2BRb%2FyWTqp8&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/eXRxehLTlx08iXYL9C5G01041200jxNB0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=zn9K4DvvD5&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/YjmfUSFBlx08iXYKfwkU01041200bV1o0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=v%2Bwxl92Luu&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5091972214358030&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OCIG6eFZw</link><guid isPermaLink="false">https://weibo.com/2831150640/OCIG6eFZw</guid><pubDate>Tue, 22 Oct 2024 06:22:06 GMT</pubDate><author>深圳卫健委</author><category>长期忍受疼痛免疫力会降低</category><category>身体疼痛不是忍忍就过去了</category></item><item><title>【发面饼一样的脸，蝴蝶形红斑！红斑狼疮终于有救[彩虹屁]】系统性红斑狼疮和狼没关系，它是一种慢性自身免疫病，好发于青年女性。得了这病，早期脸上会出现皮疹...</title><description>【发面饼一样的脸，蝴蝶形红斑！红斑狼疮终于有救&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[彩虹屁]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/4b/2022_praise_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;】系统性红斑狼疮和狼没关系，它是一种慢性自身免疫病，好发于青年女性。&lt;br&gt;&lt;br&gt;得了这病，早期脸上会出现皮疹、红斑，就像一只红色大蝴蝶。而且，体内会产生大量抗体，攻击正常的细胞、组织和器官，引起多器官受影响。&lt;br&gt;&lt;br&gt;《中国狼疮性肾炎诊断和治疗指南》显示，我国系统性红斑狼疮人数达到42.2万-98.6万人，发病率约为30.13-70.41/100000。&lt;br&gt;&lt;br&gt;系统性红斑狼疮具有高度变异性，病情大多数不稳定、易复发，会伴随一生且无法治愈。至于病因，很遗憾，还没有完全研究清楚。&lt;br&gt;&lt;br&gt;虽然不能除根疾病，但可以控制呀！&lt;br&gt;&lt;br&gt;今年9月，港大深圳医院通过“港澳药械通”政策，成功引进安全治疗红斑狼疮的靶向药物：阿伏利尤单抗。它能有效减少复发，更好地改善补体水平、血清抗体等指标，预后也较好。&lt;br&gt;&lt;br&gt;作为全国首家“港澳药械通”试点医院，截至今年9月底，港大深圳医院已引进药品26种、器械14种，已有超过4800为患者获得治疗&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[打call]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/fb_a1dacall-1e0c4593fc.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%96%B0%E9%B2%9C%E4%BA%8B%E5%84%BF%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%96%B0%E9%B2%9C%E4%BA%8B%E5%84%BF%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫新鲜事儿#&lt;/span&gt;&lt;/a&gt;（香港大学深圳医院）&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1huv45l2aifj20zk0nptc1.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1huv45kz8fmj20zk0npwhf.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCIlkr79c</link><guid isPermaLink="false">https://weibo.com/2831150640/OCIlkr79c</guid><pubDate>Tue, 22 Oct 2024 05:30:56 GMT</pubDate><author>深圳卫健委</author><category>小卫新鲜事儿</category></item><item><title>[吃惊]#女子拆快递后揉眼睛感染疱疹病毒#，快递袋，其实超脏的！快递包装袋的材质是聚乙烯、聚氯乙烯等材料，符合国家标准的，一般没有毒害。但有些包装袋是回收...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%A5%B3%E5%AD%90%E6%8B%86%E5%BF%AB%E9%80%92%E5%90%8E%E6%8F%89%E7%9C%BC%E7%9D%9B%E6%84%9F%E6%9F%93%E7%96%B1%E7%96%B9%E7%97%85%E6%AF%92%23&amp;amp;extparam=%23%E5%A5%B3%E5%AD%90%E6%8B%86%E5%BF%AB%E9%80%92%E5%90%8E%E6%8F%89%E7%9C%BC%E7%9D%9B%E6%84%9F%E6%9F%93%E7%96%B1%E7%96%B9%E7%97%85%E6%AF%92%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#女子拆快递后揉眼睛感染疱疹病毒#&lt;/span&gt;&lt;/a&gt;，快递袋，其实超脏的！&lt;br&gt;&lt;br&gt;快递包装袋的材质是聚乙烯、聚氯乙烯等材料，符合国家标准的，一般没有毒害。&lt;br&gt;&lt;br&gt;但有些包装袋是回收再加工的，可能残留大量有害物质。而且快递在中转、派送等过程中，容易携带尘土、细菌等。&lt;br&gt;&lt;br&gt;此外，快递配送员每天接触的人流量非常大，容易增加收件人感染病毒的风险。健康问题不能大意！收取快递时，记好这5点——&lt;br&gt;&lt;br&gt;①尽量无接触配送，让快递员将快递放入快递柜；&lt;br&gt;② 取包裹时，避免双手抱取；&lt;br&gt;③ 拆快递时不要直接用手撕或用嘴咬；&lt;br&gt;④ 拆完快递后，要认真洗手；&lt;br&gt;⑤ 如果取件点人流量较大，或存放地点容易受污染时，建议用75%酒精，或含氯消毒剂等消毒包裹。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（广东疾控）&lt;br&gt;&lt;br&gt;“满减”套路，你整明白了吗？&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[思考]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_sikao-ff9602dd08.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1huuzqst5k1g206o06on0h.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCHlo8PzW</link><guid isPermaLink="false">https://weibo.com/2831150640/OCHlo8PzW</guid><pubDate>Tue, 22 Oct 2024 02:58:20 GMT</pubDate><author>深圳卫健委</author><category>女子拆快递后揉眼睛感染疱疹病毒</category><category>小卫辟谣问答</category></item><item><title>💊#吃布洛芬止疼不具有成瘾性#布洛芬属于非甾体抗炎药，不会上瘾。它能缓解头痛、关节痛、偏头痛、牙痛、痛经、术后疼痛、腰痛等，还能退烧、抗炎。但它不是万...</title><description>💊&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%90%83%E5%B8%83%E6%B4%9B%E8%8A%AC%E6%AD%A2%E7%96%BC%E4%B8%8D%E5%85%B7%E6%9C%89%E6%88%90%E7%98%BE%E6%80%A7%23&amp;amp;extparam=%23%E5%90%83%E5%B8%83%E6%B4%9B%E8%8A%AC%E6%AD%A2%E7%96%BC%E4%B8%8D%E5%85%B7%E6%9C%89%E6%88%90%E7%98%BE%E6%80%A7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#吃布洛芬止疼不具有成瘾性#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;布洛芬属于非甾体抗炎药，不会上瘾。它能缓解头痛、关节痛、偏头痛、牙痛、痛经、术后疼痛、腰痛等，还能退烧、抗炎。&lt;br&gt;&lt;br&gt;但它不是万能的！如果你是心脏疾病引起的疼痛，一定要及时就医，避免耽误病情！&lt;br&gt;&lt;br&gt;另外，布洛芬不是所有人都能吃，因为它可能会——&lt;br&gt;&lt;br&gt;①孕妇：通过胎盘，对胎儿造成损害。&lt;br&gt;&lt;br&gt;②哺乳期妇女：进入乳汁，哺乳期女性妇女用药，需停止哺乳。&lt;br&gt;&lt;br&gt;③备孕的女性：延迟或阻止排卵，引起可逆性不孕。&lt;br&gt;&lt;br&gt;④消化性溃疡或胃肠道出血患者：抑制对胃肠黏膜起保护作用的环氧酶1的活性，加重溃疡或出血。&lt;br&gt;&lt;br&gt;⑤心脏疾病患者：口服高剂量（≥2400mg/日）时，可增加心脏病发作和卒中风险。&lt;br&gt;&lt;br&gt;⑥肝病、肾病的患者：布洛芬经肝脏代谢、肾脏排泄，服用后可能会加重病情。（科普中国）&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1huuylm2y0oj20u02drak4.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1huuyllwpxwj20dk0e6q3u.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCH5kbryc</link><guid isPermaLink="false">https://weibo.com/2831150640/OCH5kbryc</guid><pubDate>Tue, 22 Oct 2024 02:18:45 GMT</pubDate><author>深圳卫健委</author><category>吃布洛芬止疼不具有成瘾性</category></item><item><title>[思考]牙周病，会通过接吻传染吗？接吻时，双方会交换200种以上的菌群。如果对方患有牙周病，那接吻时交换的就是有害菌群了，致病菌很容易进入接吻对象的口腔。...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[思考]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_sikao-ff9602dd08.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;牙周病，会通过接吻传染吗？&lt;br&gt;&lt;br&gt;接吻时，双方会交换200种以上的菌群。&lt;br&gt;&lt;br&gt;如果对方患有牙周病，那接吻时交换的就是有害菌群了，致病菌很容易进入接吻对象的口腔。对于存在免疫力不足、口腔溃疡、牙出血等情况的人群，患上牙周病的风险会大大增加。&lt;br&gt;&lt;br&gt;另外，牙结石、牙列不齐、蛀牙等牙科疾病，口腔内的致病菌大大增加。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（深圳市妇幼保健院）&lt;br&gt;&lt;br&gt;单身的也可以学习一下&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1huu9dmldrhj20b80de0td.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OCBn79YWN</link><guid isPermaLink="false">https://weibo.com/2831150640/OCBn79YWN</guid><pubDate>Mon, 21 Oct 2024 11:46:06 GMT</pubDate><author>深圳卫健委</author><category>小卫辟谣问答</category></item><item><title>【注意！#错误用药真的会吃死人#[吃惊]】缓释片、控释片、肠溶片、包衣片、胶囊、化疗药、靶向药等，不能掰开或碾碎服用，达不到治疗目的事小，可能会药物中毒！...</title><description>【注意！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E9%94%99%E8%AF%AF%E7%94%A8%E8%8D%AF%E7%9C%9F%E7%9A%84%E4%BC%9A%E5%90%83%E6%AD%BB%E4%BA%BA%23&amp;amp;extparam=%23%E9%94%99%E8%AF%AF%E7%94%A8%E8%8D%AF%E7%9C%9F%E7%9A%84%E4%BC%9A%E5%90%83%E6%AD%BB%E4%BA%BA%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#错误用药真的会吃死人#&lt;/span&gt;&lt;/a&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;】缓释片、控释片、肠溶片、包衣片、胶囊、化疗药、靶向药等，不能掰开或碾碎服用，达不到治疗目的事小，可能会药物中毒！服药时，要仔细阅读药品说明书并遵医嘱；其次，老人、孕妇、儿童等特殊人群用药，要更加注意。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（国家应急广播） &lt;a href=&quot;https://video.weibo.com/show?fid=1034:5091633524572167&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;国家应急广播的微博视频&lt;/span&gt;&lt;/a&gt;&lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax1.sinaimg.cn/orj480/c7ab8f4cly1hut35gpi0lj21hc0u076o.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/i6uoCYM0lx08iWufAgyQ01041200aDMo0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=dDxUDjCQDz&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/Vn2zyvHJlx08iWueWxYs010412005ttl0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=cj1bchWY57&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/BQUSWmpGlx08iWueN2HK010412003pPi0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1729631865&amp;amp;ssig=rLLPkzfCzl&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5091633524572167&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OCACxjhNR</link><guid isPermaLink="false">https://weibo.com/2831150640/OCACxjhNR</guid><pubDate>Mon, 21 Oct 2024 09:51:21 GMT</pubDate><author>深圳卫健委</author><category>错误用药真的会吃死人</category><category>小卫辟谣问答</category></item></channel></rss>