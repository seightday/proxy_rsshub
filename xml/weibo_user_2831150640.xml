%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（中国消防）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:4953642218750013&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;中国消防的微博视频&lt;/span&gt;&lt;/a&gt; &lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax2.sinaimg.cn/orj480/003Sf5o2ly1hikv315j81j60u0140apt02.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/o0pV6Bvblx08998p5Msg01041200djjE0E010.mp4?label=mp4_720p&amp;amp;template=720x1280.24.0&amp;amp;ori=0&amp;amp;ps=1BVp4ysnknHVZu&amp;amp;Expires=1713959219&amp;amp;ssig=beq1wgeIIF&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/SrPRMQSIlx08998oqVTa010412008aXT0E010.mp4?label=mp4_hd&amp;amp;template=540x960.24.0&amp;amp;ori=0&amp;amp;ps=1BVp4ysnknHVZu&amp;amp;Expires=1713959219&amp;amp;ssig=xcXW3pChrx&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/je2TwNAylx08998ovHiU010412004CMG0E010.mp4?label=mp4_ld&amp;amp;template=360x640.24.0&amp;amp;ori=0&amp;amp;ps=1BVp4ysnknHVZu&amp;amp;Expires=1713959219&amp;amp;ssig=R6YRbvijMO&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A4953642218750013&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/ObdeDnvxf</link><guid isPermaLink="false">https://weibo.com/2831150640/ObdeDnvxf</guid><pubDate>Wed, 24 Apr 2024 08:41:05 GMT</pubDate><author>深圳卫健委</author></item><item><title>[哆啦A梦害怕]#胃病发展成胃癌的征兆# 从胃病，到胃癌，只有4步：慢性浅表性胃炎→萎缩性胃炎→肠上皮化生或异型增生→胃癌👇🏻①长期不良的饮食习惯、吸烟...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[哆啦A梦害怕]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/doraemon/dr_03haipa-32e9b53caf.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%83%83%E7%97%85%E5%8F%91%E5%B1%95%E6%88%90%E8%83%83%E7%99%8C%E7%9A%84%E5%BE%81%E5%85%86%23&amp;amp;extparam=%23%E8%83%83%E7%97%85%E5%8F%91%E5%B1%95%E6%88%90%E8%83%83%E7%99%8C%E7%9A%84%E5%BE%81%E5%85%86%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#胃病发展成胃癌的征兆#&lt;/span&gt;&lt;/a&gt; 从胃病，到胃癌，只有4步：慢性浅表性胃炎→萎缩性胃炎→肠上皮化生或异型增生→胃癌👇🏻&lt;br&gt;&lt;br&gt;①长期不良的饮食习惯、吸烟喝酒、缺乏睡眠等都会增加胃粘膜损伤的风险。&lt;br&gt;&lt;br&gt;②不警惕起来，胃粘膜加剧，形成胃炎。&lt;br&gt;&lt;br&gt;③要是还拖着，胃炎可能就会发展成胃溃疡，此时，胃粘膜损伤就处于病变阶段了。&lt;br&gt;&lt;br&gt;④还不管，胃溃疡加深，可能引起胃出血或胃穿孔。&lt;br&gt;&lt;br&gt;⑤继续作，胃内生长出异常的杯状细胞，就可能引起发育异常、形成非典型增生。中度和重度的非典型增生就有可能转变为胃癌。&lt;br&gt;&lt;br&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;以下这几类人，是胃癌高危人群，建议定期进行胃镜检查（建议每5年做一次）：&lt;br&gt;&lt;br&gt;🔹年龄大于40岁；&lt;br&gt;🔹幽门螺杆菌阳性；&lt;br&gt;🔹有胃病，包括萎缩性胃炎，慢性贫血，或者做过胃的手术；&lt;br&gt;🔹有明确胃癌家族史；&lt;br&gt;有长期不良的生活习惯，如抽烟、喝酒、一直吃腌制食品、高盐饮食的人群。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;br&gt;&lt;br&gt;一起好好保护我们的胃&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[抱一抱]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/co_a1hug-f3910d0e88.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hp1ysd40hij20u00es775.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hp1ysd52lmj20u00ni78m.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hp1ysd3iz8j20c80e6myv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/ObcQJevy0</link><guid isPermaLink="false">https://weibo.com/2831150640/ObcQJevy0</guid><pubDate>Wed, 24 Apr 2024 07:42:11 GMT</pubDate><author>深圳卫健委</author></item><item><title>【[衰]优甲乐当糖吃，7岁娃病危！全身换血4遍......】童童（化名）今年7岁，正处于喜欢吃甜的年纪。这天上午，童童爸爸看见桌上空空的药盒，觉得很奇怪，反复询...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[衰]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_shuai-285d2d97c7.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;优甲乐当糖吃，7岁娃病危！全身换血4遍......】童童（化名）今年7岁，正处于喜欢吃甜的年纪。这天上午，童童爸爸看见桌上空空的药盒，觉得很奇怪，反复询问后，童童才承认：“这个糖甜甜的很好吃，昨天把它们吃光了。”&lt;br&gt;&lt;br&gt;爸爸听完，魂都吓飞了&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;，这哪儿是什么糖，这是优甲乐，还一次性吃了150片！&lt;br&gt;&lt;br&gt;优甲乐是一种甲状腺激素药物，短期大量服用可能出现甲状腺危象，严重时可导致多器官功能衰竭，甚至死亡。童童一次性吃了150片，远超过成人75-150倍的剂量！&lt;br&gt;&lt;br&gt;家长带着童童火急火燎地冲进深圳市妇幼保健院，此时，童童已经出现低热、心率快、血压偏高等症状了，医护人员立即为童童对症治疗。进一步检查的结果显示：童童的TT4（甲状腺素）、FT4（游离甲状腺素）都爆表，测不出数值！&lt;br&gt;&lt;br&gt;服用剂量远远超过治疗量，服用时间也已经超过12小时，吸收量可能已经达到80%以上......“马上进行血浆置换！”PICU主任赵宏霞喊道。&lt;br&gt;&lt;br&gt;没过多久，第一个难题就出现了，童童逐渐出现发热、心率快、呼吸快等优甲乐中毒的症状，常规镇静也无法完成血浆置换管路，吴春远副主任医师立刻联系了麻醉科。终于，童童完成了第一次血浆置换，直到各项指标正常后，医护人员才回到值班室休息。&lt;br&gt;&lt;br&gt;还没松口气，危险再度袭来！复查甲功结果显示，童童的TT4、FT4仍然无法测出数值，TT3、FT3也明显升高，这意味着，甲状腺危象并没有解除！&lt;br&gt;&lt;br&gt;“继续血浆置换！”在这期间，童童的指标只要没有恢复，就只能继续进行血浆置换。经过4次血浆置换、总计将近一万毫升后，童童的甲功各项指标终于逐渐恢复。&lt;br&gt;&lt;br&gt;转入普通病房，又经过了3天观察照护后，童童顺利出院。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[抱一抱]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/co_a1hug-f3910d0e88.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E7%A7%91%E6%99%AE%E6%95%85%E4%BA%8B%E6%B1%87%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E7%A7%91%E6%99%AE%E6%95%85%E4%BA%8B%E6%B1%87%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫科普故事汇#&lt;/span&gt;&lt;/a&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hp1xjzhprsj20z40qc0yu.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp1xk0rd3lj20u00sqdkr.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hp1xjzjux0j20z50qdwky.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Obczqz4vJ</link><guid isPermaLink="false">https://weibo.com/2831150640/Obczqz4vJ</guid><pubDate>Wed, 24 Apr 2024 06:59:34 GMT</pubDate><author>深圳卫健委</author></item><item><title>[举杠铃]#运动后多久才可以洗澡#剧烈运动后，千万别马上洗澡🛁剧烈运动后，人体皮肤表面血管扩张，汗孔张大，排汗增多，如果马上洗热水澡，会导致心脏和大脑供...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[举杠铃]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/bb/2022_Weightlifting_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%BF%90%E5%8A%A8%E5%90%8E%E5%A4%9A%E4%B9%85%E6%89%8D%E5%8F%AF%E4%BB%A5%E6%B4%97%E6%BE%A1%23&amp;amp;extparam=%23%E8%BF%90%E5%8A%A8%E5%90%8E%E5%A4%9A%E4%B9%85%E6%89%8D%E5%8F%AF%E4%BB%A5%E6%B4%97%E6%BE%A1%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#运动后多久才可以洗澡#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;剧烈运动后，千万别马上洗澡🛁&lt;br&gt;&lt;br&gt;剧烈运动后，人体皮肤表面血管扩张，汗孔张大，排汗增多，如果马上洗热水澡，会导致心脏和大脑供血不足，轻则让人头昏眼花，重则虚脱休克，还容易诱发其他慢性疾病！&lt;br&gt;&lt;br&gt;听卫的，先给身体一个缓冲的时间，休息半小时后再洗澡&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp1u2sxwehj20rd0xsdje.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/ObbMA4k4Q</link><guid isPermaLink="false">https://weibo.com/2831150640/ObbMA4k4Q</guid><pubDate>Wed, 24 Apr 2024 04:59:13 GMT</pubDate><author>深圳卫健委</author></item><item><title>[干饭人]#很伤身体的4种早餐#不吃早餐会胖，还会伤胃伤胆，但也不能乱吃，否则一样会给身体带来损害，这4种早餐，大家避个雷[doge]👇🏻#小卫唠健康#（健康中...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[干饭人]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/cb/2022_Foodie_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%BE%88%E4%BC%A4%E8%BA%AB%E4%BD%93%E7%9A%844%E7%A7%8D%E6%97%A9%E9%A4%90%23&amp;amp;extparam=%23%E5%BE%88%E4%BC%A4%E8%BA%AB%E4%BD%93%E7%9A%844%E7%A7%8D%E6%97%A9%E9%A4%90%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#很伤身体的4种早餐#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;不吃早餐会胖，还会伤胃伤胆，但也不能乱吃，否则一样会给身体带来损害，这4种早餐，大家避个雷&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;br&gt;&lt;br&gt;问题来了，明天早餐吃什么&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[思考]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_sikao-ff9602dd08.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; &lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hp1ra953l7j20u0316dx3.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp1ra8w3z2j20m83pn7kv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Obb9meHjo</link><guid isPermaLink="false">https://weibo.com/2831150640/Obb9meHjo</guid><pubDate>Wed, 24 Apr 2024 03:22:35 GMT</pubDate><author>深圳卫健委</author></item><item><title>[许愿星]#蔡磊病情加重舌头下嘴唇已萎缩#“渐冻症，”医学上称“肌萎缩侧索硬化症”，是缓慢进展性运动神经元疾病。患者大多是青壮年，平均生存期只有3-5年，这...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[许愿星]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/a8/2022_WishingStar_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%94%A1%E7%A3%8A%E7%97%85%E6%83%85%E5%8A%A0%E9%87%8D%E8%88%8C%E5%A4%B4%E4%B8%8B%E5%98%B4%E5%94%87%E5%B7%B2%E8%90%8E%E7%BC%A9%23&amp;amp;extparam=%23%E8%94%A1%E7%A3%8A%E7%97%85%E6%83%85%E5%8A%A0%E9%87%8D%E8%88%8C%E5%A4%B4%E4%B8%8B%E5%98%B4%E5%94%87%E5%B7%B2%E8%90%8E%E7%BC%A9%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#蔡磊病情加重舌头下嘴唇已萎缩#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;“渐冻症，”医学上称“肌萎缩侧索硬化症”，是缓慢进展性运动神经元疾病。患者大多是青壮年，平均生存期只有3-5年，这种病最大的特征，就是残忍。发病后肌肉萎缩无法逆转。&lt;br&gt;&lt;br&gt;渐冻症会从一开始无法说话、无法吞咽、呼吸需要机器维持，最终瘫痪，因呼吸衰竭而亡。更可怕的是，患者会清醒地看到自己被冰冻的全过程......&lt;br&gt;&lt;br&gt;渐冻症本身就很罕见，患病率约为0.8-8.5/10万，家族遗传只占5%-10%。中国有近10万名渐冻症患者，大多数发病都是从手部开始。这种病症在早期就有一些征兆——吞咽困难，手部肌肉跳动、无力。但目前暂时没有良好的治疗方法。&lt;br&gt;&lt;br&gt;我们能做的，就是及早发现征兆，哪怕不能康复，也会提高病发时的生活质量。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（健康广东）&lt;br&gt;&lt;br&gt;愿大家都健健康康，无病无灾。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[心]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/l_xin-43af9086c0.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hp1qcnrj5kj20rs0kuzpt.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/ObaWfsqIl</link><guid isPermaLink="false">https://weibo.com/2831150640/ObaWfsqIl</guid><pubDate>Wed, 24 Apr 2024 02:50:18 GMT</pubDate><author>深圳卫健委</author></item><item><title>不开玩笑，这些食物和操作，都可能让你摄入更多微塑料，有些食物可能你每天都在吃！[吃惊]👇🏻#小卫唠健康#（四川大学华西医院）四川大学华西医院的微博视频</title><description>不开玩笑，这些食物和操作，都可能让你摄入更多微塑料，有些食物可能你每天都在吃！&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（四川大学华西医院）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5018752266207283&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;四川大学华西医院的微博视频&lt;/span&gt;&lt;/a&gt; &lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax1.sinaimg.cn/orj480/66e7ab2bly1hockw0n7dtj21hc0u00u9.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/1mIndyielx08dLI48GPK01041200ES7n0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1713959230&amp;amp;ssig=vDbytuNOZJ&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/S2pNghHHlx08dLI2CmQo01041200j1mw0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1713959230&amp;amp;ssig=huR08FtQOx&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/tXluXecTlx08dLI29Zmo01041200brQm0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1713959230&amp;amp;ssig=CG7mqzU9hU&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5018752266207283&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/Ob4TqsYnA</link><guid isPermaLink="false">https://weibo.com/2831150640/Ob4TqsYnA</guid><pubDate>Tue, 23 Apr 2024 11:26:52 GMT</pubDate><author>深圳卫健委</author></item><item><title>深圳的搬砖人只会口嗨，实际上一个比一个卷，比如今天的暴雨，也只是“洒洒水”，就算下刀子，大家也会准时出现在工位上[微笑] 阿卫想说，暴雨过后，最紧要的，...</title><description>深圳的搬砖人只会口嗨，实际上一个比一个卷，比如今天的暴雨，也只是“洒洒水”，就算下刀子，大家也会准时出现在工位上&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[微笑]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_hehe-0be7e6251f.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; 阿卫想说，暴雨过后，最紧要的，是要码住这7条提醒&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;👇🏻&lt;br&gt;&lt;br&gt;①不吃被水淹过或受污染的食品；&lt;br&gt;②不吃因停电解冻过久而腐败的食物；&lt;br&gt;③不使用未经清洗消毒的餐具；&lt;br&gt;④不喝生水，注意饮用水卫生；&lt;br&gt;⑤不吃生食，生熟分开，煮熟煮透；&lt;br&gt;⑥不要采食野蘑菇、野菜；&lt;br&gt;⑦要注重卫生，保持清洁。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt; （广东疾控）&lt;br&gt;&lt;br&gt;暴雨天下班后速速回家，路上注意安全！&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[开学季]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/72/2021_kaixueji_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp0wkjbksoj20sg0sggnn.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Ob4c0wZhH</link><guid isPermaLink="false">https://weibo.com/2831150640/Ob4c0wZhH</guid><pubDate>Tue, 23 Apr 2024 09:39:54 GMT</pubDate><author>深圳卫健委</author></item><item><title>#爱出汗和不爱出汗的人谁更健康#🥵每个人出汗多少，主要取决于身体汗腺对交感神经的活动情况以及身体对交感神经刺激做出反应的强弱，和基因、自身身体情况有关...</title><description>&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E7%88%B1%E5%87%BA%E6%B1%97%E5%92%8C%E4%B8%8D%E7%88%B1%E5%87%BA%E6%B1%97%E7%9A%84%E4%BA%BA%E8%B0%81%E6%9B%B4%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E7%88%B1%E5%87%BA%E6%B1%97%E5%92%8C%E4%B8%8D%E7%88%B1%E5%87%BA%E6%B1%97%E7%9A%84%E4%BA%BA%E8%B0%81%E6%9B%B4%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#爱出汗和不爱出汗的人谁更健康#&lt;/span&gt;&lt;/a&gt;🥵&lt;br&gt;&lt;br&gt;每个人出汗多少，主要取决于身体汗腺对交感神经的活动情况以及身体对交感神经刺激做出反应的强弱，和基因、自身身体情况有关。一般来说，男性比女性更容易出汗；体重越大的人，出汗也较多；下午比上午更容易出汗。&lt;br&gt;&lt;br&gt;汗液99%都是水，氯化钠、钾、尿素氮等只占1%。出汗除了能降温，还能可以维持皮肤健康、平衡体内的微量元素等。一定程度上，出汗确实能排出一丢丢体内代谢废物和毒素，但作用非常小，迄今为止，也没有出汗可以加速排出人体内的毒素、防病治病的有力的证据。&lt;br&gt;&lt;br&gt;其实出汗过多或过少，都不是啥好事，甚至可能是因为某些疾病所致，比如多汗症、甲亢、少汗症、甲减等，这些都是需要及早就医治疗的。&lt;br&gt;&lt;br&gt;所以，别太在意自己出汗多还是出汗少了，健健康康才最重要！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（科学辟谣）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp0u600opij20m80luac8.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hp0u60wi8wj20rs0kugnv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hp0u5zoqvlj20u00ttjvp.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/Ob3EglpQX</link><guid isPermaLink="false">https://weibo.com/2831150640/Ob3EglpQX</guid><pubDate>Tue, 23 Apr 2024 08:16:45 GMT</pubDate><author>深圳卫健委</author></item><item><title>【#三类人容易发生骨折# 不宜多走路[话筒]】专家提醒，患有腰腿病、膝关节病、老年性骨质疏松症的人，尽量少走路。#每天走多少步才合适#？专家表示，6000-8000步...</title><description>【&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E4%B8%89%E7%B1%BB%E4%BA%BA%E5%AE%B9%E6%98%93%E5%8F%91%E7%94%9F%E9%AA%A8%E6%8A%98%23&amp;amp;extparam=%23%E4%B8%89%E7%B1%BB%E4%BA%BA%E5%AE%B9%E6%98%93%E5%8F%91%E7%94%9F%E9%AA%A8%E6%8A%98%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#三类人容易发生骨折#&lt;/span&gt;&lt;/a&gt; 不宜多走路&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;】专家提醒，患有腰腿病、膝关节病、老年性骨质疏松症的人，尽量少走路。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E6%AF%8F%E5%A4%A9%E8%B5%B0%E5%A4%9A%E5%B0%91%E6%AD%A5%E6%89%8D%E5%90%88%E9%80%82%23&amp;amp;extparam=%23%E6%AF%8F%E5%A4%A9%E8%B5%B0%E5%A4%9A%E5%B0%91%E6%AD%A5%E6%89%8D%E5%90%88%E9%80%82%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#每天走多少步才合适#&lt;/span&gt;&lt;/a&gt;？专家表示，6000-8000步以内，有利于心脑血管健康，超过8000步还会增加关节的负担。另外，老人外出踏青时注意这两点：走路不看景，看景不走路；穿轻便舒适的运动鞋，不要穿太硬的皮鞋，也不要穿鞋底很薄的鞋子。 （央视网）&lt;a href=&quot;http://t.cn/A6TGASHJ&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_web_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt; &lt;span class=&quot;surl-text&quot;&gt;网页链接&lt;/span&gt;&lt;/a&gt;</description><link>https://weibo.com/2831150640/Ob3ltlElA</link><guid isPermaLink="false">https://weibo.com/2831150640/Ob3ltlElA</guid><pubDate>Tue, 23 Apr 2024 07:30:28 GMT</pubDate><author>深圳卫健委</author></item></channel></rss>