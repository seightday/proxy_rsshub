26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国） &lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htuaabhzjrj20u014lage.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htuaabmzqnj20u014lwkr.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htuaabopxej20u014lagr.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htuaabojnnj20u014lq8w.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxS19E1st</link><guid isPermaLink="false">https://weibo.com/2831150640/OxS19E1st</guid><pubDate>Fri, 20 Sep 2024 08:57:11 GMT</pubDate><author>深圳卫健委</author><category>全国爱牙日</category><category>小卫辟谣问答</category></item><item><title>[闭嘴]#过度节食减肥易导致胆囊疾病#过度快速减肥，真的会伤害身体！有研究显示，过度减肥的2~4个月内，约有1/4的人会发生胆结石。尤其是节食减肥！这么做，胆囊...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[闭嘴]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_bizui-3381378bab.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%BF%87%E5%BA%A6%E8%8A%82%E9%A3%9F%E5%87%8F%E8%82%A5%E6%98%93%E5%AF%BC%E8%87%B4%E8%83%86%E5%9B%8A%E7%96%BE%E7%97%85%23&amp;amp;extparam=%23%E8%BF%87%E5%BA%A6%E8%8A%82%E9%A3%9F%E5%87%8F%E8%82%A5%E6%98%93%E5%AF%BC%E8%87%B4%E8%83%86%E5%9B%8A%E7%96%BE%E7%97%85%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#过度节食减肥易导致胆囊疾病#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;过度快速减肥，真的会伤害身体！&lt;br&gt;&lt;br&gt;有研究显示，过度减肥的2~4个月内，约有1/4的人会发生胆结石。尤其是节食减肥！这么做，胆囊收缩功能会大大减弱，导致胆囊内黏液浓缩、钙质增加，胆结石就来了。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康广东） &lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu7pjq1epj20k80bq74q.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu7pjuzgwj20u00z4n1v.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1htu7pjnxnnj20u00h8t9w.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxRqYm29j</link><guid isPermaLink="false">https://weibo.com/2831150640/OxRqYm29j</guid><pubDate>Fri, 20 Sep 2024 07:28:02 GMT</pubDate><author>深圳卫健委</author><category>过度节食减肥易导致胆囊疾病</category><category>小卫辟谣问答</category></item><item><title>【[吃惊]48岁大姐胃胀，晚一步就胃癌！40岁以后，这个检查一定要做】最近两个月，48岁的的王姐，总觉得胃很胀。她去医院做胃肠镜检查，果然发现胃底有一处隆起！...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_chijing-59b444adb6.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;48岁大姐胃胀，晚一步就胃癌！40岁以后，这个检查一定要做】最近两个月，48岁的的王姐，总觉得胃很胀。她去医院做胃肠镜检查，果然发现胃底有一处隆起！可是，普通的胃镜检查，根本判断不出这个病变，到底是良性还是恶性。&lt;br&gt;&lt;br&gt;消化内科的医生，建议王姐再做一个“超声内镜”检查。&lt;br&gt;&lt;br&gt;超声内镜，是“超声＋内镜”的组合，能直接拍出消化道最表层（粘膜层）的彩照。医生可以通过它，看出你的胃有没有溃疡、炎症等疾病。&lt;br&gt;&lt;br&gt;检查中，超声内镜提示王姐的小鼓包，属于消化道壁5层中的第4层（这5层分别为：粘膜层、粘膜肌层、粘膜下层、固有肌层、浆膜层）。医生推测，很可能是胃间质瘤。&lt;br&gt;&lt;br&gt;胃间质瘤存在恶变风险，医生为王姐制定了“内镜下粘膜剥离术”的治疗方案。王姐对医生十分信任，立马就同意手术。&lt;br&gt;&lt;br&gt;只用了半小时，手术就顺利完成。&lt;br&gt;&lt;br&gt;术后，医生将切下来的肿瘤送去病理检查（图3），还真就是胃间质瘤！王姐心中的一块大石终于落地，高兴地说：“真是多亏了你们！”&lt;br&gt;&lt;br&gt;uu们可能会问，超声内镜那么厉害，以后能不能跳过肠胃镜，直接做超声内镜检查呢？&lt;br&gt;&lt;br&gt;一般来说，当你做完了胃肠镜、B超、磁共振等影像检查后，还不能明确诊断疾病，医生才会建议你做超声内镜检查。而且，不同检查的侧重点不同，不能互相取代。至于适合做什么检查，请乖乖听医生的话。&lt;br&gt;&lt;br&gt;另外，40岁以上的人，最好定期做肠胃镜检查。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫说案例#&lt;/span&gt;&lt;/a&gt;（深圳市人民医院）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu69hdpb3j20fu0df0tp.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu69heh6pj20w00o0q58.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1htu69hdgtfj20fu0dfq48.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxR6EEWMG</link><guid isPermaLink="false">https://weibo.com/2831150640/OxR6EEWMG</guid><pubDate>Fri, 20 Sep 2024 06:37:59 GMT</pubDate><author>深圳卫健委</author><category>小卫说案例</category></item><item><title>🪥[嘻嘻]#别再拉锯式刷牙了# 横向拉锯式刷牙，是刷牙中最不好的方式！长期横向拉锯式刷牙、刷牙用力过猛，或使用刷毛过硬的牙刷，都会导致牙颈部的磨损、牙龈...</title><description>🪥&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[嘻嘻]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_xixi-643ef6e48d.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%88%AB%E5%86%8D%E6%8B%89%E9%94%AF%E5%BC%8F%E5%88%B7%E7%89%99%E4%BA%86%23&amp;amp;extparam=%23%E5%88%AB%E5%86%8D%E6%8B%89%E9%94%AF%E5%BC%8F%E5%88%B7%E7%89%99%E4%BA%86%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#别再拉锯式刷牙了#&lt;/span&gt;&lt;/a&gt; 横向拉锯式刷牙，是刷牙中最不好的方式！&lt;br&gt;&lt;br&gt;长期横向拉锯式刷牙、刷牙用力过猛，或使用刷毛过硬的牙刷，都会导致牙颈部的磨损、牙龈萎缩，还可能会折断牙齿&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[二哈]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_erha-139d0e07bd.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;！&lt;br&gt;&lt;br&gt;如果已经出现了早期的口腔健康问题，又没有及时就医，再错误刷牙，口腔就会有异味、长龋齿、经常塞牙等等，口腔情况也会越来越糟糕。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（健康中国、健康广东）&lt;br&gt;&lt;br&gt;最后，跟着卫再复习一次刷牙的正确姿势✅&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu3t0tts1j20go0m8goc.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu3t0urptj20go0m8wg8.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu3t0ursyj20go0m8ta4.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1htu3t0uzhfj20go0m8gng.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu3t0zqc8j20go0m8407.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htu3t0vd1tj20go0m8gnd.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htu3t0zn4gj20go0m876f.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htu3t1gp6bj20go0m8wgt.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1htu3t0ynr1j20go0m8jte.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxQy9pXdz</link><guid isPermaLink="false">https://weibo.com/2831150640/OxQy9pXdz</guid><pubDate>Fri, 20 Sep 2024 05:12:59 GMT</pubDate><author>深圳卫健委</author><category>别再拉锯式刷牙了</category><category>小卫辟谣问答</category></item><item><title>[哆啦A梦吃惊]#这可能是瘦肚子最高效的运动#人体有2种脂肪——①皮下脂肪：能被我们捏起来的，比如“拜拜肉”等。②内脏脂肪：看不见摸不着，它们隐藏在内脏里（...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[哆啦A梦吃惊]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/doraemon/dr_01chijing-31d5542cca.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E8%BF%99%E5%8F%AF%E8%83%BD%E6%98%AF%E7%98%A6%E8%82%9A%E5%AD%90%E6%9C%80%E9%AB%98%E6%95%88%E7%9A%84%E8%BF%90%E5%8A%A8%23&amp;amp;extparam=%23%E8%BF%99%E5%8F%AF%E8%83%BD%E6%98%AF%E7%98%A6%E8%82%9A%E5%AD%90%E6%9C%80%E9%AB%98%E6%95%88%E7%9A%84%E8%BF%90%E5%8A%A8%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#这可能是瘦肚子最高效的运动#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;人体有2种脂肪——&lt;br&gt;&lt;br&gt;①皮下脂肪：能被我们捏起来的，比如“拜拜肉”等。&lt;br&gt;&lt;br&gt;②内脏脂肪：看不见摸不着，它们隐藏在内脏里（比如肝脏、胰脏等），比如腰腹部的赘肉等，减肥基本对它们无效&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[裂开]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/fc_liekai-9df295d44f.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;真正要瘦小肚子，最佳的运动方式是无氧运动+有氧运动。比如可以先做力量训练：卷腹、平板支撑等，再进行有氧运动：慢跑、快走、游泳、骑自行车、跳绳等。&lt;br&gt;&lt;br&gt;因为只有通过无氧运动提高基础代谢，再通过有氧运动代谢供能，才能真正消耗脂肪。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（科普中国）&lt;br&gt;&lt;br&gt;最重要是少吃点&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[doge]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_doge-be7f768d78.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu2630mtaj20u00i0gne.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1htu262yrytg20hq06g0tn.gif&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxQb9niMy</link><guid isPermaLink="false">https://weibo.com/2831150640/OxQb9niMy</guid><pubDate>Fri, 20 Sep 2024 04:16:19 GMT</pubDate><author>深圳卫健委</author><category>这可能是瘦肚子最高效的运动</category><category>小卫辟谣问答</category></item><item><title>[苦涩]#大量掉头发是多囊卵巢的症状之一#多囊卵巢综合征(PCOS)是一种非常复杂，又最为常见的内分泌及代谢异常所致的疾病。得了多囊，会出现月经失调（月经稀发、...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[苦涩]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/7e/2021_bitter_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%A4%A7%E9%87%8F%E6%8E%89%E5%A4%B4%E5%8F%91%E6%98%AF%E5%A4%9A%E5%9B%8A%E5%8D%B5%E5%B7%A2%E7%9A%84%E7%97%87%E7%8A%B6%E4%B9%8B%E4%B8%80%23&amp;amp;extparam=%23%E5%A4%A7%E9%87%8F%E6%8E%89%E5%A4%B4%E5%8F%91%E6%98%AF%E5%A4%9A%E5%9B%8A%E5%8D%B5%E5%B7%A2%E7%9A%84%E7%97%87%E7%8A%B6%E4%B9%8B%E4%B8%80%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#大量掉头发是多囊卵巢的症状之一#&lt;/span&gt;&lt;/a&gt;&lt;br&gt;&lt;br&gt;多囊卵巢综合征(PCOS)是一种非常复杂，又最为常见的内分泌及代谢异常所致的疾病。&lt;br&gt;&lt;br&gt;得了多囊，会出现月经失调（月经稀发、闭经或阴道不规则出血）、肥胖、不孕、多毛、脱发、痤疮等，且约有4%-18%的育龄女性会被它的影响。另外，它还会影响全身代谢，导致年龄偏大者发生心血管。&lt;br&gt;&lt;br&gt;而且，这病与肥胖“狼狈为奸”！&lt;br&gt;&lt;br&gt;肥胖的人，会出现胰岛素抵抗的情况，导致内分泌混乱，增加了患多囊卵巢综合征的风险。&lt;br&gt;&lt;br&gt;即使你不肥胖，但只要患上多囊卵巢综合征，也会存在高胰岛素抵抗的可能。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%BE%9F%E8%B0%A3%E9%97%AE%E7%AD%94%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫辟谣问答#&lt;/span&gt;&lt;/a&gt;（科学辟谣、深圳市人民医院）&lt;br&gt;&lt;br&gt;不管啥病，该治就得治！&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu1clumbyj20rs0ku0wn.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1htu1cm2f6lj20u00qg0wd.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1htu1clv8eij20jg0f6jsc.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;</description><link>https://weibo.com/2831150640/OxPZF6pz8</link><guid isPermaLink="false">https://weibo.com/2831150640/OxPZF6pz8</guid><pubDate>Fri, 20 Sep 2024 03:48:00 GMT</pubDate><author>深圳卫健委</author><category>大量掉头发是多囊卵巢的症状之一</category><category>小卫辟谣问答</category></item></channel></rss>