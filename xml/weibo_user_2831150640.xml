g.cn/large/a8bfee30gy1hs68ttbsxzj20ll0g8myf.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hs68ttg0dwj216g0u0tcl.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hs68ttgkyoj216g0u0786.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs68tti4yrj216g0u0tcb.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs68ttjl0uj216g0u0djw.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hs68ttq8xsj216g0u0n0t.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OpYqagKOO</link><guid isPermaLink="false">https://weibo.com/2831150640/OpYqagKOO</guid><pubDate>Tue, 30 Jul 2024 10:32:50 GMT</pubDate><author>深圳卫健委</author><category>疾病风险预报</category></item><item><title>🥚鸡蛋放进冰箱前，要不要先洗一洗？鸡蛋买回家后，可以放在阴凉干燥处，最好放在冰箱里冷藏，但注意要和蔬果、肉等分开存放，避免交叉污染。一般情况下，买来...</title><description>🥚鸡蛋放进冰箱前，要不要先洗一洗？&lt;br&gt;&lt;br&gt;鸡蛋买回家后，可以放在阴凉干燥处，最好放在冰箱里冷藏，但注意要和蔬果、肉等分开存放，避免交叉污染。&lt;br&gt;&lt;br&gt;一般情况下，买来的鸡蛋不需要清洗。鸡蛋的外壳，表面有一层保护膜，它能减少微生物进入鸡蛋内部。如果清洗过度，保护膜被破坏，即使放入冰箱了，鸡蛋也很容易变质。&lt;br&gt;&lt;br&gt;如果蛋壳表面有鸡粪、泥土等脏东西，可以简单清洗一下，然后在短时间内优先吃完。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（深圳疾控）&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hs66e4fl1ej20eg08ywff.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs66e4hpccj20om18qq7s.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OpXRWDJum</link><guid isPermaLink="false">https://weibo.com/2831150640/OpXRWDJum</guid><pubDate>Tue, 30 Jul 2024 09:08:33 GMT</pubDate><author>深圳卫健委</author><category>小卫来辟谣</category></item><item><title>【[骷髅]#广东夫妻上山误采断肠草煲汤中毒入院#】近日，广东一对夫妇在山里采了“五指毛桃”煲汤，喝完后口吐白沫、意识不清、心跳骤停，甚至多器官功能衰竭！经...</title><description>【&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[骷髅]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_kulou-116c59c096.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B9%BF%E4%B8%9C%E5%A4%AB%E5%A6%BB%E4%B8%8A%E5%B1%B1%E8%AF%AF%E9%87%87%E6%96%AD%E8%82%A0%E8%8D%89%E7%85%B2%E6%B1%A4%E4%B8%AD%E6%AF%92%E5%85%A5%E9%99%A2%23&amp;amp;extparam=%23%E5%B9%BF%E4%B8%9C%E5%A4%AB%E5%A6%BB%E4%B8%8A%E5%B1%B1%E8%AF%AF%E9%87%87%E6%96%AD%E8%82%A0%E8%8D%89%E7%85%B2%E6%B1%A4%E4%B8%AD%E6%AF%92%E5%85%A5%E9%99%A2%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#广东夫妻上山误采断肠草煲汤中毒入院#&lt;/span&gt;&lt;/a&gt;】近日，广东一对夫妇在山里采了“五指毛桃”煲汤，喝完后口吐白沫、意识不清、心跳骤停，甚至多器官功能衰竭！经检查，2人被确诊为误服断肠草中毒。&lt;br&gt;&lt;br&gt;断肠草全株有剧毒，不能吃！为什么这么多广东人误食断肠草？因为这玩意儿和煲汤煮水常用的料太像了！它的花容易“金银花”混淆，它的根外观与“五指毛桃”的根十分相似......&lt;br&gt;&lt;br&gt;断肠草中毒的潜伏期很短，一般吃进去2个小时内就会发病。断肠草中毒后，可能会出现呼吸麻痹、眩晕、肌肉弛缓无力、视力减退、腹泻腹痛、恶心呕吐等症状。&lt;br&gt;&lt;br&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[话筒]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/o_huatong-0a3e80b147.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;误食后，这样自救——&lt;br&gt;&lt;br&gt;①立即催吐。但中毒者出现昏迷，则不宜进行人为催吐，避免引起窒息。&lt;br&gt;&lt;br&gt;②马上拨打120，尽快送医院治疗。&lt;br&gt;&lt;br&gt;③保留吃剩的食物、用剩的植物，以供检验。&lt;br&gt;&lt;br&gt;④共同进食者无论是否发病，也应立即到医院进行检查。&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（深圳市第三人民医院）&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hs6337imkxj20u011ln2j.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs6337hqlvj20m808cwet.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OpX7z2VBY</link><guid isPermaLink="false">https://weibo.com/2831150640/OpX7z2VBY</guid><pubDate>Tue, 30 Jul 2024 07:14:16 GMT</pubDate><author>深圳卫健委</author><category>广东夫妻上山误采断肠草煲汤中毒入院</category><category>小卫唠健康</category></item><item><title>为了保持脸蛋水嫩有弹性，有些uu陷入了疯狂！起床、睡前、泡澡……无时无刻都在敷面膜。今天，阿卫又来泼冷水了：面膜没敷对，烂脸又浪费[二哈]！#小卫来辟谣#（...</title><description>为了保持脸蛋水嫩有弹性，有些uu陷入了疯狂！起床、睡前、泡澡……无时无刻都在敷面膜。今天，阿卫又来泼冷水了：面膜没敷对，烂脸又浪费&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[二哈]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/others/d_erha-139d0e07bd.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;！&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E6%9D%A5%E8%BE%9F%E8%B0%A3%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫来辟谣#&lt;/span&gt;&lt;/a&gt;（四川大学华西医院）&lt;a href=&quot;https://video.weibo.com/show?fid=1034:5061755290714149&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;url-icon&quot;&gt;&lt;img style=&quot;width: 1rem;height: 1rem&quot; src=&quot;https://h5.sinaimg.cn/upload/2015/09/25/3/timeline_card_small_video_default.png&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;span class=&quot;surl-text&quot;&gt;四川大学华西医院的微博视频&lt;/span&gt;&lt;/a&gt; &lt;br clear=&quot;both&quot;&gt;&lt;div style=&quot;clear: both&quot;&gt;&lt;/div&gt;&lt;video controls=&quot;controls&quot; poster=&quot;https://tvax2.sinaimg.cn/orj480/66e7ab2bly1hs5rpot47bj21hc0u0di8.jpg&quot; style=&quot;width: 100%&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/GGUe4C43lx08gOYYmhAs01041200lBtX0E010.mp4?label=mp4_720p&amp;amp;template=1280x720.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1722413939&amp;amp;ssig=eZLTv%2FEEdh&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/tAGfbLRRlx08gOYYs7Be01041200aBHl0E010.mp4?label=mp4_hd&amp;amp;template=852x480.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1722413939&amp;amp;ssig=Ak8PYSFYB2&amp;amp;KID=unistore,video&quot;&gt;&lt;source src=&quot;https://f.video.weibocdn.com/o0/lxDkgUaulx08gOYXziOQ010412006Eqn0E010.mp4?label=mp4_ld&amp;amp;template=640x360.25.0&amp;amp;ori=0&amp;amp;ps=1CwnkDw1GXwCQx&amp;amp;Expires=1722413939&amp;amp;ssig=lPt2TWXJGW&amp;amp;KID=unistore,video&quot;&gt;&lt;p&gt;视频无法显示，请前往&lt;a href=&quot;https://video.weibo.com/show?fid=1034%3A5061755290714149&quot; target=&quot;_blank&quot; rel=&quot;noopener noreferrer&quot;&gt;微博视频&lt;/a&gt;观看。&lt;/p&gt;&lt;/video&gt;</description><link>https://weibo.com/2831150640/OpWXermfZ</link><guid isPermaLink="false">https://weibo.com/2831150640/OpWXermfZ</guid><pubDate>Tue, 30 Jul 2024 06:48:49 GMT</pubDate><author>深圳卫健委</author><category>小卫来辟谣</category></item><item><title>【[开摆]6岁娃近视1000度！妈妈心态崩了，医生：别急，过几天再来】6岁的小阳，一放暑假，就开始“报复性”玩手机和各种电子产品！这天，小阳喊着眼睛看不清，爸...</title><description>【[开摆]6岁娃近视1000度！妈妈心态崩了，医生：别急，过几天再来】6岁的小阳，一放暑假，就开始“报复性”玩手机和各种电子产品！这天，小阳喊着眼睛看不清，爸妈赶紧带他检查眼睛。&lt;br&gt;&lt;br&gt;结果一出：近视1000度？？？&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[衰]&quot; src=&quot;https://h5.sinaimg.cn/m/emoticon/icon/default/d_shuai-285d2d97c7.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;医生倒是不慌，让小阳先回家滴几天阿托品后，再来复查。&lt;br&gt;&lt;br&gt;妈妈心态崩了，回家后每天按医嘱滴药，一秒都不敢松懈，还预约了深圳市眼科医院近视防控专家崔冬梅。&lt;br&gt;&lt;br&gt;经过详查，最终确认小阳为双眼远视150度。&lt;br&gt;&lt;br&gt;原来，在上一次检查中，小阳双眼晶状体的厚度分别为4.51mm和4.2mm（正常范围：3~4mm），前房深度分别为2.87mm和3.05mm，晶状体的变厚、前移，导致小阳“高度近视”。&lt;br&gt;&lt;br&gt;滴了几天阿托品后，小阳的晶状体和前房深度都回到了正常的厚度和位置，屈光度也有明显变化。而这，就是长时间近距离用眼，或短时间内近距离用眼过多导致的假性近视！&lt;br&gt;&lt;br&gt;真性近视与假性近视的区别——&lt;br&gt;&lt;br&gt;①眼轴：真性近视会变长，假性近视在正常范围内；&lt;br&gt;②成像：都在视网膜前。&lt;br&gt;&lt;br&gt;在阿托品等睫状肌麻痹药物的作用下，小阳的睫状肌慢慢放松，晶状体从凸起状态，慢慢变平，位置也逐渐向后移，恢复到正常150度远视储备的状态。&lt;br&gt;&lt;br&gt;接下来，只要持续用药，日常注意用眼习惯，多进行户外活动，少看近处，小阳的视力就能逐渐恢复啦。&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[老师夸夸]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/f0/2023_Theteacherpraises_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;（深圳市眼科医院）&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E8%AF%B4%E6%A1%88%E4%BE%8B%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫说案例#&lt;/span&gt;&lt;/a&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs60h8zddpj20i20udq69.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hs60h8w4q3j20h10c074s.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax3.sinaimg.cn/large/a8bfee30gy1hs60h8kxz0j20hs0983ys.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;</description><link>https://weibo.com/2831150640/OpWwUtoKk</link><guid isPermaLink="false">https://weibo.com/2831150640/OpWwUtoKk</guid><pubDate>Tue, 30 Jul 2024 05:43:58 GMT</pubDate><author>深圳卫健委</author><category>小卫说案例</category></item><item><title>[干饭人]这几种我们常吃的食物，有些可能有毒！阿卫建议，煮之前最好先焯水👇🏻#小卫唠健康#（广东疾控） [图片][图片][图片][图片][图片][图片][图片][图片...</title><description>&lt;span class=&quot;url-icon&quot;&gt;&lt;img alt=&quot;[干饭人]&quot; src=&quot;https://face.t.sinajs.cn/t4/appstyle/expression/ext/normal/cb/2022_Foodie_org.png&quot; style=&quot;width:1em; height:1em;&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;/span&gt;这几种我们常吃的食物，有些可能有毒！阿卫建议，煮之前最好先焯水👇🏻&lt;a href=&quot;https://m.weibo.cn/search?containerid=231522type%3D1%26t%3D10%26q%3D%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&amp;amp;extparam=%23%E5%B0%8F%E5%8D%AB%E5%94%A0%E5%81%A5%E5%BA%B7%23&quot; data-hide=&quot;&quot;&gt;&lt;span class=&quot;surl-text&quot;&gt;#小卫唠健康#&lt;/span&gt;&lt;/a&gt;（广东疾控） &lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hs5x778iq5j20rs15oq6z.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hs5x777bm1j20rs10hjw7.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hs5x77au3rj20rs171jw8.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hs5x77hlugj20rs1dq45b.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax2.sinaimg.cn/large/a8bfee30gy1hs5x77boazj20rs16oafv.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax1.sinaimg.cn/large/a8bfee30gy1hs5x77e21pj20rs1jkjyz.jpg&quot; referrerpolicy=&quot;no-referrer&quot;&gt;&lt;br&gt;&lt;br&gt;&lt;img style=&quot;&quot; src=&quot;https://tvax4.sinaimg.cn/large/a8bfee30gy1hs5x77k